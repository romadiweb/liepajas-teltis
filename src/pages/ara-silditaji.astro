---
import ProductCategoryLayout from '../layouts/ProductCategoryLayout.astro';
import { getProductsByPageSlug } from '../lib/tentProducts';

const products = await getProductsByPageSlug('ara-silditaji');
const filters = [
	{ label: 'Visi āra sildītāji', active: true },
	...Array.from(new Set(products.map((product) => product.category))).map((label) => ({ label })),
];
---

<ProductCategoryLayout
	breadcrumbCurrent="Āra sildītāji"
	description="Āra sildītāji vēsākiem vakariem, lai viesiem būtu patīkami uzturēties pasākuma zonā."
	filters={filters}
	products={products}
	title="Āra sildītāji"
/>
