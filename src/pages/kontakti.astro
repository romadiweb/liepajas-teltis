---
import ArrowRight from '@lucide/astro/icons/arrow-right';
import CalendarDays from '@lucide/astro/icons/calendar-days';
import CheckCircle2 from '@lucide/astro/icons/circle-check';
import Clock3 from '@lucide/astro/icons/clock-3';
import Leaf from '@lucide/astro/icons/leaf';
import Mail from '@lucide/astro/icons/mail';
import MapPin from '@lucide/astro/icons/map-pin';
import Phone from '@lucide/astro/icons/phone';
import Send from '@lucide/astro/icons/send';
import UserRound from '@lucide/astro/icons/user-round';
import BaseLayout from '../layouts/BaseLayout.astro';
import FloatingActions from '../components/common/FloatingActions.astro';
import ScrollToTop from '../components/common/ScrollToTop.astro';
import SiteFooter from '../components/common/SiteFooter.astro';
import SiteHeader from '../components/common/SiteHeader.astro';

const contactMethods = [
	{
		href: 'tel:+37129373231',
		icon: Phone,
		title: 'Tālrunis',
		value: '+371 29 373 231',
	},
	{
		href: 'mailto:info@liepajasteltis.lv',
		icon: Mail,
		title: 'E-pasts',
		value: 'info@liepajasteltis.lv',
	},
	{
		href: 'https://www.google.com/maps/search/?api=1&query=Darbn%C4%ABcu%20iela%205%2C%20Liep%C4%81ja',
		icon: MapPin,
		title: 'Adrese',
		value: 'Darbnīcu iela 5,\nLiepāja, LV-3401',
	},
	{
		href: null,
		icon: Clock3,
		title: 'Darba laiks',
		value: '24/7',
	},
];

const supportPoints = ['Ātra atbilde', 'Individuāla pieeja', 'Profesionāls serviss'];
---

<BaseLayout title="Kontakti | Liepājas teltis" description="Sazinieties ar Liepājas teltis par telšu un inventāra nomu jūsu pasākumam.">
	<SiteHeader />
	<main class="page-shell contact-page" aria-labelledby="contact-page-title">
		<FloatingActions />
		<ScrollToTop />

		<section class="contact-page__hero">
			<nav class="breadcrumb-trail contact-page__breadcrumbs" aria-label="Lapas ceļš">
				<a href="/">Sākums</a>
				<ArrowRight aria-hidden="true" />
				<span>Kontakti</span>
			</nav>

			<div class="contact-page__intro">
				<h1 id="contact-page-title">Kontakti</h1>
				<div class="contact-page__rule" aria-hidden="true"></div>
				<p>Sazinieties ar mums - mēs ar prieku palīdzēsim plānot jūsu pasākumu!</p>
			</div>
		</section>

		<section class="contact-methods" aria-label="Kontaktinformācija">
			{
				contactMethods.map(({ href, icon: Icon, title, value }) => {
					const content = (
						<>
							<Icon aria-hidden="true" />
							<strong>{title}</strong>
							<span>{value}</span>
						</>
					);

					return href ? (
						<a class="contact-method" href={href}>
							{content}
						</a>
					) : (
						<div class="contact-method">{content}</div>
					);
				})
			}
		</section>

		<section class="contact-message" aria-label="Rakstiet mums">
			<form class="contact-form-card" name="kontaktu-zina" method="post" data-netlify="true">
				<input type="hidden" name="form-name" value="kontaktu-zina" />
				<div class="contact-form-card__heading">
					<h2>Rakstiet mums</h2>
					<div class="contact-page__rule" aria-hidden="true"></div>
					<p>Aizpildiet formu, un mēs ar jums sazināsimies tuvākajā laikā.</p>
				</div>

				<div class="contact-form-card__grid">
					<label>
						<span>Vārds, Uzvārds</span>
						<input name="vards_uzvards" type="text" autocomplete="name" placeholder="Vārds, Uzvārds" required />
					</label>
					<label>
						<span>E-pasts</span>
						<input name="epasts" type="email" autocomplete="email" placeholder="E-pasts" required />
					</label>
					<label class="contact-form-card__full">
						<span>Tālruņa numurs</span>
						<input name="telefona_numurs" type="tel" autocomplete="tel" placeholder="Tālruņa numurs" />
					</label>
					<label class="contact-form-card__full">
						<span>Ziņojums</span>
						<textarea name="zinojums" rows="5" placeholder="Ziņojums" required></textarea>
					</label>
				</div>

				<p class="contact-form-card__privacy">
					Nosūtot ziņojumu, piekrītat, ka sazināsimies par jūsu jautājumu. Plašāk:
					<a href="/privatuma-politika">privātuma politika</a>.
				</p>

				<button class="contact-form-card__button" type="submit">
					<span>Nosūtīt</span>
					<ArrowRight aria-hidden="true" />
				</button>
			</form>

			<aside class="contact-support" aria-label="Saziņas priekšrocības">
				<Leaf class="contact-support__leaf" aria-hidden="true" />
				<h2>Sazinieties jebkurā jums ērtā veidā</h2>
				<div class="contact-page__rule" aria-hidden="true"></div>
				<p>Atbildam ātri un palīdzam atrast piemērotāko risinājumu jūsu pasākumam.</p>
				<ul>
					{
						supportPoints.map((point) => (
							<li>
								<CheckCircle2 aria-hidden="true" />
								<span>{point}</span>
							</li>
						))
					}
				</ul>
			</aside>
		</section>

		<section class="contact-map" aria-label="Atrašanās vieta">
			<div class="contact-map__visual" aria-hidden="true">
				<span class="contact-map__water"></span>
				<span class="contact-map__road contact-map__road--one"></span>
				<span class="contact-map__road contact-map__road--two"></span>
				<span class="contact-map__road contact-map__road--three"></span>
				<span class="contact-map__road contact-map__road--four"></span>
				<span class="contact-map__road contact-map__road--five"></span>
				<span class="contact-map__marker">
					<MapPin aria-hidden="true" />
				</span>
				<div class="contact-map__controls">
					<span>+</span>
					<span>-</span>
					<span>⌾</span>
				</div>
			</div>
			<div class="contact-map__card">
				<h2>Liepājas Teltis</h2>
				<p>Darbnīcu iela 5,<br />Liepāja, LV-3401</p>
				<a href="https://www.google.com/maps/search/?api=1&query=Darbn%C4%ABcu%20iela%205%2C%20Liep%C4%81ja" target="_blank" rel="noreferrer">
					<span>Skatīt kartē</span>
					<ArrowRight aria-hidden="true" />
				</a>
			</div>
		</section>

		<section class="contact-cta" aria-label="Pieteikt nomu">
			<div class="contact-cta__icon">
				<CalendarDays aria-hidden="true" />
			</div>
			<div>
				<h2>Plāno savu pasākumu?</h2>
				<p>Mēs palīdzēsim radīt tieši tādu atmosfēru, kādu esi iecerējis.</p>
			</div>
			<a href="/pieteikt-nomu">
				<span>Pieteikt nomu</span>
				<Send aria-hidden="true" />
			</a>
		</section>
	</main>
	<SiteFooter />
</BaseLayout>

<style>
	.contact-page {
		position: relative;
		padding: clamp(1.6rem, 3.8vw, 3.1rem) clamp(1rem, 3vw, 1.5rem) 0;
		overflow: hidden;
		background: var(--color-background);
	}

	.contact-page::before {
		position: absolute;
		left: max(-4rem, calc(50% - 47rem));
		top: 10rem;
		width: clamp(8rem, 16vw, 13rem);
		height: clamp(6rem, 11vw, 9rem);
		background-image: radial-gradient(circle, rgba(155, 135, 115, 0.28) 1.25px, transparent 1.55px);
		background-size: 0.82rem 0.82rem;
		content: "";
		opacity: 0.78;
		pointer-events: none;
	}

	.contact-page__hero,
	.contact-methods,
	.contact-message,
	.contact-map,
	.contact-cta {
		position: relative;
		z-index: 1;
		width: min(100%, 1160px);
		margin-inline: auto;
	}

	.contact-page__breadcrumbs {
		margin-bottom: clamp(1.5rem, 2.7vw, 2rem);
	}

	.contact-page__intro {
		max-width: 34rem;
	}

	.contact-page__intro h1,
	.contact-form-card h2,
	.contact-support h2,
	.contact-cta h2 {
		margin: 0;
		color: var(--color-bark);
		font-family: Georgia, "Times New Roman", serif;
		font-weight: 500;
		letter-spacing: 0;
	}

	.contact-page__intro h1 {
		font-size: clamp(2.8rem, 5.6vw, 4.45rem);
		line-height: 1;
	}

	.contact-page__rule {
		width: 2.8rem;
		height: 1px;
		margin: 1rem 0 1.1rem;
		background: var(--color-primary);
	}

	.contact-page__intro p {
		max-width: 25rem;
		margin: 0;
		color: var(--color-text-muted);
		font-size: clamp(0.95rem, 1.2vw, 1.05rem);
		font-weight: 500;
		line-height: 1.68;
	}

	.contact-methods {
		margin-top: clamp(2.7rem, 5vw, 4.2rem);
		display: grid;
		grid-template-columns: repeat(4, minmax(0, 1fr));
		overflow: hidden;
		background: rgba(255, 255, 255, 0.44);
		border: 1px solid rgba(222, 212, 198, 0.78);
		border-radius: 8px;
		box-shadow: 0 16px 38px rgba(75, 64, 56, 0.05);
	}

	.contact-method {
		min-height: 8.6rem;
		padding: 1rem clamp(1rem, 2.4vw, 2.4rem);
		display: grid;
		place-items: center;
		align-content: center;
		color: var(--color-bark);
		text-align: center;
		text-decoration: none;
		border-right: 1px solid rgba(185, 167, 143, 0.42);
	}

	.contact-method:last-child {
		border-right: 0;
	}

	.contact-method:hover {
		color: var(--color-bark);
		transform: translateY(-2px);
	}

	.contact-method svg {
		width: 1.8rem;
		height: 1.8rem;
		margin-bottom: 1.1rem;
		color: var(--color-primary);
		stroke-width: 1.8;
	}

	.contact-method strong {
		display: block;
		margin-bottom: 0.55rem;
		color: var(--color-bark);
		font-family: Georgia, "Times New Roman", serif;
		font-size: 1.05rem;
		font-weight: 500;
		line-height: 1.2;
	}

	.contact-method span {
		white-space: pre-line;
		color: var(--color-text-muted);
		font-size: 0.88rem;
		font-weight: 560;
		line-height: 1.55;
	}

	.contact-message {
		margin-top: clamp(2.1rem, 4.5vw, 3.8rem);
		display: grid;
		grid-template-columns: minmax(0, 1.05fr) minmax(18rem, 0.9fr);
		gap: clamp(1.4rem, 3vw, 2.2rem);
		align-items: stretch;
	}

	.contact-form-card,
	.contact-support {
		border: 1px solid rgba(222, 212, 198, 0.82);
		border-radius: 8px;
		box-shadow: 0 18px 44px rgba(75, 64, 56, 0.06);
	}

	.contact-form-card {
		padding: clamp(1.4rem, 3vw, 2.5rem);
		background: rgba(255, 255, 255, 0.48);
	}

	.contact-form-card__heading h2,
	.contact-support h2 {
		font-size: clamp(1.75rem, 3vw, 2.35rem);
		line-height: 1.08;
	}

	.contact-form-card__heading p,
	.contact-support p {
		max-width: 23rem;
		margin: 0 0 1.35rem;
		color: var(--color-text-muted);
		font-size: 0.9rem;
		font-weight: 500;
		line-height: 1.65;
	}

	.contact-form-card__grid {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 0.75rem;
	}

	.contact-form-card label {
		min-width: 0;
		display: grid;
		gap: 0.35rem;
	}

	.contact-form-card label > span {
		position: absolute;
		width: 1px;
		height: 1px;
		overflow: hidden;
		clip: rect(0, 0, 0, 0);
		white-space: nowrap;
	}

	.contact-form-card__full {
		grid-column: 1 / -1;
	}

	.contact-form-card input,
	.contact-form-card textarea {
		width: 100%;
		color: var(--color-bark);
		background: rgba(255, 255, 255, 0.72);
		border: 1px solid rgba(222, 212, 198, 0.92);
		border-radius: 4px;
		font: inherit;
		font-size: 0.88rem;
	}

	.contact-form-card input {
		min-height: 2.45rem;
		padding: 0 0.85rem;
	}

	.contact-form-card textarea {
		min-height: 6rem;
		padding: 0.75rem 0.85rem;
		line-height: 1.5;
		resize: vertical;
	}

	.contact-form-card input::placeholder,
	.contact-form-card textarea::placeholder {
		color: rgba(115, 103, 93, 0.72);
	}

	.contact-form-card input:focus,
	.contact-form-card textarea:focus {
		border-color: var(--color-primary);
		outline: none;
		box-shadow: var(--focus-ring);
	}

	.contact-form-card__privacy {
		max-width: 26rem;
		margin: 0.9rem 0 0;
		color: var(--color-text-muted);
		font-size: 0.78rem;
		font-weight: 520;
		line-height: 1.42;
	}

	.contact-form-card__privacy a {
		font-weight: 700;
	}

	.contact-form-card__button,
	.contact-cta a {
		min-height: 2.75rem;
		padding: 0 1.45rem;
		display: inline-flex;
		align-items: center;
		justify-content: center;
		gap: 0.75rem;
		color: var(--color-surface);
		background: #4f5d32;
		border: 0;
		border-radius: 999px;
		box-shadow: 0 14px 28px rgba(79, 93, 50, 0.2);
		cursor: pointer;
		font: inherit;
		font-size: 0.75rem;
		font-weight: 850;
		letter-spacing: 0.06em;
		text-decoration: none;
		text-transform: uppercase;
	}

	.contact-form-card__button {
		margin-top: 1.15rem;
	}

	.contact-form-card__button:hover,
	.contact-cta a:hover {
		color: var(--color-surface);
		background: var(--color-primary-hover);
		transform: translateY(-2px);
	}

	.contact-form-card__button svg,
	.contact-cta a svg {
		width: 1rem;
		height: 1rem;
	}

	.contact-support {
		position: relative;
		padding: clamp(1.55rem, 3.4vw, 3rem);
		overflow: hidden;
		background:
			linear-gradient(135deg, rgba(237, 228, 215, 0.86), rgba(246, 241, 231, 0.72)),
			radial-gradient(circle at 12% 100%, rgba(203, 183, 154, 0.24), transparent 11rem);
	}

	.contact-support__leaf {
		width: clamp(3.4rem, 7vw, 5rem);
		height: clamp(3.4rem, 7vw, 5rem);
		margin-bottom: clamp(1.2rem, 2.2vw, 1.8rem);
		color: rgba(138, 146, 113, 0.62);
		stroke-width: 1.25;
	}

	.contact-support h2 {
		max-width: 11em;
	}

	.contact-support ul {
		margin: 1.45rem 0 0;
		padding: 0;
		display: grid;
		gap: 0.72rem;
		list-style: none;
	}

	.contact-support li {
		display: flex;
		align-items: center;
		gap: 0.58rem;
		color: var(--color-text-muted);
		font-size: 0.9rem;
		font-weight: 560;
	}

	.contact-support li svg {
		width: 1rem;
		height: 1rem;
		color: var(--color-primary);
		stroke-width: 1.8;
	}

	.contact-map {
		position: relative;
		height: clamp(15rem, 29vw, 19rem);
		margin-top: clamp(2.2rem, 4vw, 3.2rem);
		overflow: hidden;
		background: #e9e1d4;
		border-radius: 8px;
		box-shadow: 0 20px 48px rgba(75, 64, 56, 0.08);
	}

	.contact-map__visual {
		position: absolute;
		inset: 0;
		overflow: hidden;
		background:
			linear-gradient(115deg, transparent 0 13%, rgba(211, 222, 202, 0.72) 13% 24%, transparent 24% 100%),
			linear-gradient(28deg, transparent 0 44%, rgba(216, 225, 205, 0.82) 44% 58%, transparent 58% 100%),
			linear-gradient(90deg, rgba(199, 218, 219, 0.72) 0 24%, transparent 24% 100%),
			#ece8df;
	}

	.contact-map__visual::before,
	.contact-map__visual::after {
		position: absolute;
		inset: 0;
		content: "";
		pointer-events: none;
	}

	.contact-map__visual::before {
		background-image:
			linear-gradient(84deg, transparent 0 48%, rgba(255, 255, 255, 0.84) 48.35% 49.5%, transparent 49.85% 100%),
			linear-gradient(8deg, transparent 0 54%, rgba(255, 255, 255, 0.72) 54.35% 55.45%, transparent 55.8% 100%),
			linear-gradient(143deg, transparent 0 42%, rgba(255, 255, 255, 0.62) 42.25% 43.1%, transparent 43.45% 100%);
		opacity: 0.95;
	}

	.contact-map__visual::after {
		background-image: radial-gradient(circle, rgba(155, 135, 115, 0.14) 1px, transparent 1.3px);
		background-size: 0.72rem 0.72rem;
		opacity: 0.38;
	}

	.contact-map__water {
		position: absolute;
		inset: -7% auto -9% -4%;
		width: 27%;
		background:
			radial-gradient(circle at 72% 34%, rgba(255, 255, 255, 0.4), transparent 2.4rem),
			#accdd1;
		clip-path: polygon(0 0, 76% 0, 62% 17%, 82% 32%, 60% 49%, 74% 68%, 54% 100%, 0 100%);
	}

	.contact-map__road {
		position: absolute;
		height: 0.42rem;
		background: rgba(255, 255, 255, 0.76);
		border: 1px solid rgba(213, 204, 190, 0.64);
		border-radius: 999px;
		box-shadow: 0 1px 0 rgba(185, 167, 143, 0.12);
	}

	.contact-map__road--one {
		left: 13%;
		top: 30%;
		width: 70%;
		transform: rotate(-10deg);
	}

	.contact-map__road--two {
		left: 25%;
		top: 59%;
		width: 66%;
		transform: rotate(13deg);
	}

	.contact-map__road--three {
		left: 31%;
		top: 12%;
		width: 52%;
		transform: rotate(39deg);
	}

	.contact-map__road--four {
		left: 38%;
		top: 23%;
		width: 0.42rem;
		height: 72%;
		transform: rotate(14deg);
	}

	.contact-map__road--five {
		left: 57%;
		top: -7%;
		width: 0.42rem;
		height: 93%;
		transform: rotate(-20deg);
	}

	.contact-map__marker {
		position: absolute;
		left: 50%;
		top: 48%;
		z-index: 1;
		width: 2.8rem;
		height: 2.8rem;
		display: grid;
		place-items: center;
		color: #4f5d32;
		background: rgba(255, 255, 255, 0.74);
		border-radius: 999px;
		box-shadow: 0 10px 24px rgba(75, 64, 56, 0.16);
		transform: translate(-50%, -50%);
	}

	.contact-map__marker svg {
		width: 1.8rem;
		height: 1.8rem;
		fill: #4f5d32;
		stroke-width: 1.8;
	}

	.contact-map__controls {
		position: absolute;
		right: 1rem;
		top: 50%;
		z-index: 2;
		overflow: hidden;
		display: grid;
		background: rgba(255, 255, 255, 0.86);
		border: 1px solid rgba(222, 212, 198, 0.82);
		border-radius: 8px;
		box-shadow: var(--shadow-soft);
		transform: translateY(-50%);
	}

	.contact-map__controls span {
		width: 2.2rem;
		height: 2.1rem;
		display: grid;
		place-items: center;
		color: var(--color-bark);
		border-bottom: 1px solid rgba(222, 212, 198, 0.82);
		font-size: 1rem;
		font-weight: 800;
		line-height: 1;
	}

	.contact-map__controls span:last-child {
		border-bottom: 0;
		font-size: 0.92rem;
	}

	.contact-map__card {
		position: absolute;
		top: 50%;
		left: clamp(1.2rem, 3vw, 2.4rem);
		z-index: 1;
		width: min(15rem, calc(100% - 2rem));
		padding: 1.25rem 1.35rem;
		background: rgba(255, 255, 255, 0.88);
		border: 1px solid rgba(222, 212, 198, 0.84);
		border-radius: 8px;
		box-shadow: var(--shadow-soft);
		transform: translateY(-50%);
	}

	.contact-map__card h2 {
		margin: 0;
		color: var(--color-bark);
		font-family: Georgia, "Times New Roman", serif;
		font-size: 1.15rem;
		font-weight: 500;
	}

	.contact-map__card p {
		margin: 0.65rem 0 0.9rem;
		color: var(--color-text-muted);
		font-size: 0.86rem;
		font-weight: 560;
		line-height: 1.48;
	}

	.contact-map__card a {
		display: inline-flex;
		align-items: center;
		gap: 0.5rem;
		color: var(--color-bark);
		font-size: 0.8rem;
		font-weight: 700;
		text-decoration: none;
	}

	.contact-map__card a svg {
		width: 0.9rem;
		height: 0.9rem;
	}

	.contact-cta {
		margin-top: clamp(1.6rem, 3.2vw, 2.4rem);
		margin-bottom: clamp(2.2rem, 4vw, 3.2rem);
		padding: clamp(1rem, 2vw, 1.4rem) clamp(1.2rem, 3vw, 2rem);
		display: grid;
		grid-template-columns: auto minmax(0, 1fr) auto;
		align-items: center;
		gap: clamp(1rem, 2.4vw, 1.6rem);
		background: rgba(255, 255, 255, 0.44);
		border: 1px solid rgba(222, 212, 198, 0.84);
		border-radius: 8px;
