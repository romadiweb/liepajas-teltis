---
import ProductCategoryLayout from '../layouts/ProductCategoryLayout.astro';
import { getTentProducts } from '../lib/tentProducts';

const products = await getTentProducts();
const filters = [
	{ label: 'Visas teltis', active: true },
	...Array.from(new Set(products.map((product) => product.category))).map((label) => ({ label })),
];
---

<ProductCategoryLayout
	breadcrumbCurrent="Teltis"
	description="Kvalitatīvas un elegantas teltis jebkuram pasākumam - no nelielām svinībām līdz lieliem notikumiem."
	filters={filters}
	products={products}
	title="Teltis"
/>
