---
import ArrowRight from '@lucide/astro/icons/arrow-right';
import Armchair from '@lucide/astro/icons/armchair';
import Award from '@lucide/astro/icons/award';
import BaseLayout from '../layouts/BaseLayout.astro';
import CalendarDays from '@lucide/astro/icons/calendar-days';
import FloatingActions from '../components/common/FloatingActions.astro';
import Heater from '@lucide/astro/icons/heater';
import Layers from '@lucide/astro/icons/layers';
import Mail from '@lucide/astro/icons/mail';
import MapPin from '@lucide/astro/icons/map-pin';
import MessageCircle from '@lucide/astro/icons/message-circle';
import PackageCheck from '@lucide/astro/icons/package-check';
import Phone from '@lucide/astro/icons/phone';
import ScrollToTop from '../components/common/ScrollToTop.astro';
import Send from '@lucide/astro/icons/send';
import ShieldCheck from '@lucide/astro/icons/shield-check';
import SiteFooter from '../components/common/SiteFooter.astro';
import SiteHeader from '../components/common/SiteHeader.astro';
import Sparkles from '@lucide/astro/icons/sparkles';
import Table from '@lucide/astro/icons/table';
import Tent from '@lucide/astro/icons/tent';
import Truck from '@lucide/astro/icons/truck';
import UserRound from '@lucide/astro/icons/user-round';

const heroImage =
	'https://images.unsplash.com/photo-1679984740405-6e15c2df8680?auto=format&fit=crop&ixlib=rb-4.1.0&q=82&w=1800';

const heroFeatures = [
	{
		description: 'Pārbaudīts inventārs',
		icon: Award,
		label: 'Kvalitāte',
	},
	{
		description: 'Piegādājam un uzstādām',
		icon: Truck,
		label: 'Piegāde',
	},
	{
		description: 'Pieredze un atbildība',
		icon: ShieldCheck,
		label: 'Uzticami',
	},
];

const categoryItems = [
	{
		alt: 'Balta pasākumu telts plašā zālienā',
		href: '#kontakti',
		icon: Tent,
		image:
			'https://images.unsplash.com/photo-1675376616537-c8aa9ddc9977?auto=format&fit=crop&ixlib=rb-4.1.0&q=80&w=900',
		title: 'Teltis',
	},
	{
		alt: 'Pasākumu telts interjers ar grīdas segumu un gaismām',
		href: '#kontakti',
		icon: Layers,
		image:
			'https://images.unsplash.com/photo-1724125082683-49b0e812046f?q=80&w=1335&auto=format&fit=crop&ixlib=rb-4.1.0&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D',
		title: 'Grīdas segumi',
	},
	{
		alt: 'Āra pasākuma zona ar baltiem krēsliem un galdiem',
		href: '#kontakti',
		icon: Table,
		image:
			'https://images.unsplash.com/photo-1653518882586-588362773209?auto=format&fit=crop&ixlib=rb-4.1.0&q=80&w=900',
		title: 'Galdi un krēsli',
	},
	{
		alt: 'Iedegts āra sildītājs vakara pasākumā',
		href: '#kontakti',
		icon: Heater,
		image:
			'https://images.unsplash.com/photo-1563692309855-3a626e81e518?auto=format&fit=crop&ixlib=rb-4.1.0&q=80&w=900',
		title: 'Āra sildītāji',
	},
	{
		alt: 'Āra atpūtas zona ar mīkstām sēdvietām',
		href: '#kontakti',
		icon: Armchair,
		image:
			'https://images.unsplash.com/photo-1776008107357-0c18d761ca72?q=80&w=1170&auto=format&fit=crop&ixlib=rb-4.1.0&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D',
		title: 'Pufi',
	},
	{
		alt: 'Pasākuma galda dekori ar svecēm un aksesuāriem',
		href: '#kontakti',
		icon: Sparkles,
		image:
			'https://images.unsplash.com/photo-1519225421980-715cb0215aed?auto=format&fit=crop&ixlib=rb-4.1.0&q=80&w=900',
		title: 'Pasākumu aksesuāri',
	},
];

const contactLinks = [
	{
		href: 'tel:+37129373231',
		icon: Phone,
		label: 'Zvaniet',
		value: '+371 29 373 231',
	},
	{
		href: 'mailto:info@liepajasteltis.lv',
		icon: Mail,
		label: 'E-pasts',
		value: 'info@liepajasteltis.lv',
	},
	{
		href: '#kontakti',
		icon: MapPin,
		label: 'Bāze',
		value: 'Liepāja - visa Latvija',
	},
];

---

<BaseLayout>
	<SiteHeader />
	<main id="top" class="page-shell" aria-label="Liepājas Teltis">
		<FloatingActions />
		<ScrollToTop />
		<section class="landing-hero" aria-labelledby="landing-hero-title">
			<div class="landing-hero__shell">
				<div class="landing-hero__content">
					<p class="landing-hero__eyebrow">Telšu noma Liepājā un visā Latvijā</p>
					<h1 id="landing-hero-title"><span>Radām vietu</span> īpašiem mirkļiem</h1>
					<p class="landing-hero__lead">
						Kvalitatīvas teltis un inventārs jebkuram pasākumam - no nelielām svinībām līdz lieliem
						notikumiem.
					</p>

					<div class="landing-hero__features" aria-label="Pakalpojuma priekšrocības">
						{
							heroFeatures.map(({ description, icon: Icon, label }) => (
								<article class="landing-hero__feature">
									<Icon aria-hidden="true" />
									<strong>{label}</strong>
									<span>{description}</span>
								</article>
							))
						}
					</div>

					<a class="landing-hero__cta" href="#kontakti">
						<span>Pieteikt nomu</span>
						<ArrowRight aria-hidden="true" />
					</a>
				</div>

				<div class="landing-hero__dots" aria-hidden="true"></div>
				<figure class="landing-hero__media" aria-label="Pasākumu telts piemērs">
					<img
						alt="Balta pasākumu telts ar dekoratīvām gaismām zaļā ārtelpā"
						decoding="async"
						fetchpriority="high"
						src={heroImage}
					/>
				</figure>
			</div>
		</section>

		<section class="categories-section" id="kategorijas" aria-labelledby="categories-title" data-reveal-section>
			<div class="categories-section__inner">
				<div class="categories-section__intro">
					<p class="categories-section__eyebrow">Kategorijas</p>
					<h2 id="categories-title">Nomas inventārs</h2>
					<p>
						Piedāvājam plašu inventāra klāstu, lai jūsu pasākums būtu izdevies līdz pēdējam sīkumam.
					</p>
				</div>

				<div class="categories-section__grid" aria-label="Nomas inventāra kategorijas">
					{
						categoryItems.map(({ alt, href, icon: Icon, image, title }, index) => (
							<a class="card category-card" href={href} style={`--card-index: ${index};`} aria-label={`${title} - pieteikt nomu`}>
								<figure class="category-card__image">
									<img alt={alt} decoding="async" loading="lazy" src={image} />
								</figure>
								<span class="category-card__badge" aria-hidden="true">
									<Icon />
								</span>
								<div class="card-body category-card__body">
									<h3 class="card-title">{title}</h3>
									<ArrowRight aria-hidden="true" />
								</div>
							</a>
						))
					}
				</div>
			</div>
		</section>

		<section class="contact-section" id="pieteikums" aria-labelledby="contact-title">
			<div class="contact-section__inner">
				<div class="contact-section__info">
					<div>
						<p class="contact-section__eyebrow">Sazināties</p>
						<h2 id="contact-title">Pastāstiet par savu <span>pasākumu</span></h2>
						<p class="contact-section__lead">
							Aizpildiet pieteikuma formu vai zvaniet - atbildēsim 24 stundu laikā ar piedāvājumu, kas
							pielāgots jūsu svinībām.
						</p>
					</div>

					<div class="contact-section__links" aria-label="Kontaktinformācija">
						{
							contactLinks.map(({ href, icon: Icon, label, value }) => (
								<a href={href} class="contact-link">
									<span class="contact-link__icon">
										<Icon aria-hidden="true" />
									</span>
									<span>
										<strong>{label}</strong>
										<span>{value}</span>
									</span>
								</a>
							))
						}
					</div>
				</div>

				<form class="contact-form" name="noma-pieteikums" method="post" data-netlify="true">
					<input type="hidden" name="form-name" value="noma-pieteikums" />

					<fieldset class="fieldset contact-form__field">
						<label class="fieldset-legend" for="contact-name">Vārds, uzvārds</label>
						<div class="contact-form__control">
							<UserRound aria-hidden="true" />
							<input
								class="input contact-form__input"
								id="contact-name"
								name="vards_uzvards"
								type="text"
								autocomplete="name"
								required
							/>
						</div>
					</fieldset>

					<fieldset class="fieldset contact-form__field">
						<label class="fieldset-legend" for="contact-phone">Telefona numurs</label>
						<div class="contact-form__control">
							<Phone aria-hidden="true" />
							<input
								class="input contact-form__input"
								id="contact-phone"
								name="telefona_numurs"
								type="tel"
								autocomplete="tel"
								required
							/>
						</div>
					</fieldset>

					<fieldset class="fieldset contact-form__field contact-form__field--full">
						<label class="fieldset-legend" for="contact-email">Epasts</label>
						<div class="contact-form__control">
							<Mail aria-hidden="true" />
							<input
								class="input contact-form__input"
								id="contact-email"
								name="epasts"
								type="email"
								autocomplete="email"
								required
							/>
						</div>
					</fieldset>

					<fieldset class="fieldset contact-form__field">
						<label class="fieldset-legend" for="contact-date">Pasākuma datums</label>
						<div class="contact-form__control contact-form__control--date">
							<CalendarDays aria-hidden="true" />
							<input class="input contact-form__input" id="contact-date" name="pasakuma_datums" type="date" required />
						</div>
					</fieldset>

					<fieldset class="fieldset contact-form__field">
						<label class="fieldset-legend" for="contact-location">Pasākuma norises vieta</label>
						<div class="contact-form__control">
							<MapPin aria-hidden="true" />
							<input
								class="input contact-form__input"
								id="contact-location"
								name="pasakuma_norises_vieta"
								type="text"
								required
							/>
						</div>
					</fieldset>

					<fieldset class="fieldset contact-form__field contact-form__field--full">
						<label class="fieldset-legend" for="contact-inventory">Vēlamais inventārs</label>
						<div class="contact-form__control contact-form__control--textarea">
							<PackageCheck aria-hidden="true" />
							<textarea
								class="textarea contact-form__textarea"
								id="contact-inventory"
								name="velamais_inventars"
								rows="5"
								required
							></textarea>
						</div>
					</fieldset>

					<div class="contact-form__footer">
						<p>Nosūtot formu, piekrītat, ka sazināsimies par jūsu pieteikumu.</p>
						<button class="btn contact-form__button" type="submit">
							<span>Nosūtīt pieteikumu</span>
							<Send aria-hidden="true" />
						</button>
					</div>
				</form>
			</div>
		</section>
	</main>
	<SiteFooter />
</BaseLayout>

<style>
	.landing-hero {
		position: relative;
		min-height: clamp(39rem, 70vw, 46rem);
		padding: clamp(4rem, 7vw, 6.25rem) 0 clamp(3.8rem, 6vw, 5rem);
		overflow: hidden;
		background:
			radial-gradient(circle at 72% 26%, rgba(203, 183, 154, 0.18), transparent 22rem),
			var(--color-background);
	}

	.landing-hero__shell {
		position: relative;
		max-width: 1200px;
		min-height: clamp(30rem, 55vw, 36rem);
		margin: 0 auto;
		padding: 0 clamp(1.4rem, 4vw, 2rem);
		display: grid;
		align-items: center;
	}

	.landing-hero__content {
		position: relative;
		z-index: 3;
		width: min(33.5rem, 46vw);
	}

	.landing-hero__eyebrow {
		margin: 0 0 1rem;
		color: var(--color-primary);
		font-size: 0.75rem;
		font-weight: 800;
		letter-spacing: 0.14em;
		line-height: 1.3;
		text-transform: uppercase;
	}

	.landing-hero h1 {
		max-width: 9.5em;
		margin: 0;
		color: var(--color-bark);
		font-size: clamp(3rem, 6vw, 5.2rem);
		font-weight: 500;
		letter-spacing: 0;
		line-height: 0.98;
	}

	.landing-hero h1 span {
		color: var(--color-primary);
	}

	.landing-hero__lead {
		max-width: 27rem;
		margin: clamp(1.2rem, 2vw, 1.55rem) 0 0;
		color: var(--color-text-muted);
		font-size: clamp(0.98rem, 1.2vw, 1.1rem);
		font-weight: 500;
		line-height: 1.72;
	}

	.landing-hero__features {
		margin-top: clamp(1.6rem, 3vw, 2.2rem);
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: clamp(0.85rem, 2vw, 1.5rem);
		max-width: 29rem;
	}

	.landing-hero__feature {
		display: grid;
		justify-items: start;
		gap: 0.34rem;
		color: var(--color-bark);
		font-size: 0.8rem;
		line-height: 1.35;
	}

	.landing-hero__feature svg {
		width: 2rem;
		height: 2rem;
		margin-bottom: 0.14rem;
		color: var(--color-primary);
		stroke-width: 1.8;
	}

	.landing-hero__feature strong {
		font-size: 0.72rem;
		font-weight: 850;
		letter-spacing: 0.09em;
		text-transform: uppercase;
	}

	.landing-hero__feature span {
		max-width: 8rem;
		color: var(--color-text-muted);
	}

	.landing-hero__cta {
		width: fit-content;
		min-height: 3.9rem;
		margin-top: clamp(1.45rem, 3vw, 2rem);
		padding: 0 1.65rem 0 1.95rem;
		display: inline-flex;
		align-items: center;
		gap: 1rem;
		color: var(--color-surface);
		background: #5f6f3c;
		border-radius: 999px;
		font-size: 0.82rem;
		font-weight: 850;
		letter-spacing: 0.04em;
		text-decoration: none;
		text-transform: uppercase;
		box-shadow: 0 16px 34px rgba(75, 64, 56, 0.12);
	}

	.landing-hero__cta:hover {
		color: var(--color-surface);
		background: #536332;
		transform: translateY(-2px);
	}

	.landing-hero__cta svg {
		width: 1.05rem;
		height: 1.05rem;
		stroke-width: 2.4;
	}

	.landing-hero__dots {
		position: absolute;
		z-index: 1;
		right: min(29vw, 23rem);
		bottom: clamp(0.6rem, 1.6vw, 1.45rem);
		width: clamp(12rem, 18vw, 15.5rem);
		height: clamp(9.4rem, 13.8vw, 12.2rem);
		background-image: radial-gradient(circle, rgba(155, 135, 115, 0.34) 1.35px, transparent 1.55px);
		background-position: 0 0;
		background-size: 0.92rem 0.92rem;
		opacity: 0.82;
	}

	.landing-hero__media {
		position: absolute;
		z-index: 2;
		top: clamp(1.8rem, 4vw, 2.7rem);
		right: calc(50% - 50vw);
		width: min(58vw, 53rem);
		height: clamp(26rem, 44vw, 36rem);
		margin: 0;
		overflow: hidden;
		clip-path: polygon(30% 0, 100% 0, 100% 100%, 26% 100%, 0 55%);
	}

	.landing-hero__media::after {
		position: absolute;
		inset: 0;
		background: linear-gradient(90deg, rgba(75, 64, 56, 0.08), transparent 42%);
		content: "";
		pointer-events: none;
	}

	.landing-hero__media img {
		width: 100%;
		height: 100%;
		display: block;
		object-fit: cover;
		object-position: 49% 48%;
	}

	.categories-section {
		position: relative;
		padding: clamp(3.7rem, 7vw, 5.6rem) clamp(1.2rem, 4vw, 2rem) clamp(4.1rem, 7vw, 6.2rem);
		background: var(--color-background);
		overflow: hidden;
	}

	.categories-section::before {
		position: absolute;
		inset: 7% auto auto 50%;
		width: min(46rem, 86vw);
		height: min(46rem, 86vw);
		background: radial-gradient(circle, rgba(203, 183, 154, 0.22), transparent 64%);
		content: "";
		pointer-events: none;
		transform: translateX(-50%);
	}

	.categories-section__inner {
		position: relative;
		z-index: 1;
		max-width: 1100px;
		margin: 0 auto;
	}

	.categories-section__intro {
		max-width: 35rem;
		margin: 0 auto;
		text-align: center;
	}

	.categories-section__eyebrow {
		margin: 0 0 0.58rem;
		color: var(--color-primary);
		font-size: 0.68rem;
		font-weight: 850;
		letter-spacing: 0.15em;
		line-height: 1.3;
		text-transform: uppercase;
	}

	.categories-section h2 {
		margin: 0;
		color: var(--color-bark);
		font-size: clamp(2.05rem, 4vw, 3.35rem);
		font-weight: 500;
		letter-spacing: 0;
		line-height: 1.05;
	}

	.categories-section__intro p:last-child {
		max-width: 31rem;
		margin: 1rem auto 0;
		color: var(--color-text-muted);
		font-size: clamp(0.94rem, 1.4vw, 1.05rem);
		font-weight: 500;
		line-height: 1.65;
	}

	.categories-section__grid {
		margin-top: clamp(2.2rem, 5vw, 3.35rem);
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: clamp(1rem, 2.4vw, 1.55rem);
	}

	.category-card {
		position: relative;
		display: block;
		min-width: 0;
		color: var(--color-bark);
		background: rgba(255, 255, 255, 0.72);
		border: 1px solid rgba(222, 212, 198, 0.72);
		border-radius: 8px;
		box-shadow: 0 18px 38px rgba(75, 64, 56, 0.09);
		text-decoration: none;
		transition:
			box-shadow 180ms ease,
			transform 180ms ease;
	}

	.category-card:hover {
		color: var(--color-bark);
		box-shadow: 0 24px 48px rgba(75, 64, 56, 0.13);
		transform: translateY(-5px);
	}

	.category-card__image {
		aspect-ratio: 1.58 / 1;
		margin: 0.55rem 0.55rem 0;
		overflow: hidden;
		border-radius: 6px;
		background: var(--color-background-soft);
	}

	.category-card__image img {
		width: 100%;
		height: 100%;
		display: block;
		object-fit: cover;
		transition: transform 520ms ease;
	}

	.category-card:hover .category-card__image img {
		transform: scale(1.055);
	}

	.category-card__badge {
		position: absolute;
		top: 0.34rem;
		left: 0.38rem;
		width: 3.45rem;
		height: 3.45rem;
		display: grid;
		place-items: center;
		color: var(--color-surface);
		background: #6b7a4a;
		border: 1px solid rgba(255, 255, 255, 0.26);
		border-radius: 999px;
		box-shadow: 0 14px 26px rgba(75, 64, 56, 0.14);
	}

	.category-card__badge svg {
		width: 1.45rem;
		height: 1.45rem;
		stroke-width: 1.75;
	}

	.category-card__body {
		min-height: 4.6rem;
		padding: 1.05rem 1rem 1.08rem;
		display: flex;
		flex-direction: row;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
	}

	.category-card__body h3 {
		flex: 1 1 auto;
		min-width: 0;
		margin: 0;
		color: inherit;
		font-size: clamp(1rem, 1.8vw, 1.22rem);
		font-weight: 500;
		line-height: 1.2;
	}

	.category-card__body svg {
		width: 1.05rem;
		height: 1.05rem;
		flex: 0 0 auto;
		color: var(--color-bark);
		stroke-width: 2.1;
		transition: transform 180ms ease;
	}

	.category-card:hover .category-card__body svg {
		transform: translateX(4px);
	}

	.contact-section {
		position: relative;
		padding: clamp(4.6rem, 8vw, 7.2rem) clamp(1.2rem, 4vw, 2rem) clamp(4.8rem, 8vw, 7.6rem);
		background: var(--color-background);
		overflow: hidden;
	}

	.contact-section::before {
		position: absolute;
		inset: -1.4rem -3.4rem auto auto;
		width: min(34rem, 56vw);
		height: min(22rem, 34vw);
		background-image: radial-gradient(circle, rgba(155, 135, 115, 0.34) 1.35px, transparent 1.55px);
		background-size: 0.92rem 0.92rem;
		content: "";
		opacity: 0.82;
		pointer-events: none;
	}

	.contact-section__inner {
		position: relative;
		z-index: 1;
		max-width: 1160px;
		margin: 0 auto;
		display: grid;
		grid-template-columns: minmax(18rem, 0.78fr) minmax(31rem, 1.08fr);
		gap: clamp(2.4rem, 7vw, 5.6rem);
		align-items: start;
	}

	.contact-section__info {
		min-height: 38.5rem;
