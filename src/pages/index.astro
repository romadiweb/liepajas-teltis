---
import ArrowRight from '@lucide/astro/icons/arrow-right';
import Armchair from '@lucide/astro/icons/armchair';
import Award from '@lucide/astro/icons/award';
import BaseLayout from '../layouts/BaseLayout.astro';
import FloatingActions from '../components/common/FloatingActions.astro';
import Heater from '@lucide/astro/icons/heater';
import Layers from '@lucide/astro/icons/layers';
import ScrollToTop from '../components/common/ScrollToTop.astro';
import ShieldCheck from '@lucide/astro/icons/shield-check';
import SiteFooter from '../components/common/SiteFooter.astro';
import SiteHeader from '../components/common/SiteHeader.astro';
import Sparkles from '@lucide/astro/icons/sparkles';
import Table from '@lucide/astro/icons/table';
import Tent from '@lucide/astro/icons/tent';
import Truck from '@lucide/astro/icons/truck';

const heroImage =
	'https://images.unsplash.com/photo-1679984740405-6e15c2df8680?auto=format&fit=crop&ixlib=rb-4.1.0&q=82&w=1800';

const heroFeatures = [
	{
		description: 'Pārbaudīts inventārs',
		icon: Award,
		label: 'Kvalitāte',
	},
	{
		description: 'Piegādājam un uzstādām',
		icon: Truck,
		label: 'Piegāde',
	},
	{
		description: 'Pieredze un atbildība',
		icon: ShieldCheck,
		label: 'Uzticami',
	},
];

const categoryItems = [
	{
		alt: 'Balta pasākumu telts plašā zālienā',
		href: '#kontakti',
		icon: Tent,
		image:
			'https://images.unsplash.com/photo-1675376616537-c8aa9ddc9977?auto=format&fit=crop&ixlib=rb-4.1.0&q=80&w=900',
		title: 'Teltis',
	},
	{
		alt: 'Pasākumu telts interjers ar grīdas segumu un gaismām',
		href: '#kontakti',
		icon: Layers,
		image:
			'https://images.unsplash.com/photo-1651065697481-bc08bb5ad40d?auto=format&fit=crop&ixlib=rb-4.1.0&q=80&w=900',
		title: 'Grīdas segumi',
	},
	{
		alt: 'Āra pasākuma zona ar baltiem krēsliem un galdiem',
		href: '#kontakti',
		icon: Table,
		image:
			'https://images.unsplash.com/photo-1653518882586-588362773209?auto=format&fit=crop&ixlib=rb-4.1.0&q=80&w=900',
		title: 'Galdi un krēsli',
	},
	{
		alt: 'Iedegts āra sildītājs vakara pasākumā',
		href: '#kontakti',
		icon: Heater,
		image:
			'https://images.unsplash.com/photo-1563692309855-3a626e81e518?auto=format&fit=crop&ixlib=rb-4.1.0&q=80&w=900',
		title: 'Āra sildītāji',
	},
	{
		alt: 'Āra atpūtas zona ar mīkstām sēdvietām',
		href: '#kontakti',
		icon: Armchair,
		image:
			'https://images.unsplash.com/photo-1761534602786-ebebdd9e9c0d?auto=format&fit=crop&ixlib=rb-4.1.0&q=80&w=900',
		title: 'Pufi',
	},
	{
		alt: 'Pasākuma galda dekori ar svecēm un aksesuāriem',
		href: '#kontakti',
		icon: Sparkles,
		image:
			'https://images.unsplash.com/photo-1519225421980-715cb0215aed?auto=format&fit=crop&ixlib=rb-4.1.0&q=80&w=900',
		title: 'Pasākumu aksesuāri',
	},
];

---

<BaseLayout>
	<SiteHeader />
	<main id="top" class="page-shell" aria-label="Liepājas Teltis">
		<FloatingActions />
		<ScrollToTop />
		<section class="landing-hero" aria-labelledby="landing-hero-title">
			<div class="landing-hero__shell">
				<div class="landing-hero__content">
					<p class="landing-hero__eyebrow">Telšu noma Liepājā un visā Latvijā</p>
					<h1 id="landing-hero-title"><span>Radām vietu</span> īpašiem mirkļiem</h1>
					<p class="landing-hero__lead">
						Kvalitatīvas teltis un inventārs jebkuram pasākumam - no nelielām svinībām līdz lieliem
						notikumiem.
					</p>

					<div class="landing-hero__features" aria-label="Pakalpojuma priekšrocības">
						{
							heroFeatures.map(({ description, icon: Icon, label }) => (
								<article class="landing-hero__feature">
									<Icon aria-hidden="true" />
									<strong>{label}</strong>
									<span>{description}</span>
								</article>
							))
						}
					</div>

					<a class="landing-hero__cta" href="#kontakti">
						<span>Pieteikt nomu</span>
						<ArrowRight aria-hidden="true" />
					</a>
				</div>

				<div class="landing-hero__dots" aria-hidden="true"></div>
				<figure class="landing-hero__media" aria-label="Pasākumu telts piemērs">
					<img
						alt="Balta pasākumu telts ar dekoratīvām gaismām zaļā ārtelpā"
						decoding="async"
						fetchpriority="high"
						src={heroImage}
					/>
				</figure>
			</div>
		</section>

		<section class="categories-section" id="kategorijas" aria-labelledby="categories-title" data-reveal-section>
			<div class="categories-section__inner">
				<div class="categories-section__intro">
					<p class="categories-section__eyebrow">Kategorijas</p>
					<h2 id="categories-title">Nomas inventārs</h2>
					<p>
						Piedāvājam plašu inventāra klāstu, lai jūsu pasākums būtu izdevies līdz pēdējam sīkumam.
					</p>
				</div>

				<div class="categories-section__grid" aria-label="Nomas inventāra kategorijas">
					{
						categoryItems.map(({ alt, href, icon: Icon, image, title }, index) => (
							<a class="card category-card" href={href} style={`--card-index: ${index};`} aria-label={`${title} - pieteikt nomu`}>
								<figure class="category-card__image">
									<img alt={alt} decoding="async" loading="lazy" src={image} />
								</figure>
								<span class="category-card__badge" aria-hidden="true">
									<Icon />
								</span>
								<div class="card-body category-card__body">
									<h3 class="card-title">{title}</h3>
									<ArrowRight aria-hidden="true" />
								</div>
							</a>
						))
					}
				</div>
			</div>
		</section>
	</main>
	<SiteFooter />
</BaseLayout>

<style>
	.landing-hero {
		position: relative;
		min-height: clamp(39rem, 70vw, 46rem);
		padding: clamp(4rem, 7vw, 6.25rem) 0 clamp(3.8rem, 6vw, 5rem);
		overflow: hidden;
		background:
			radial-gradient(circle at 72% 26%, rgba(203, 183, 154, 0.18), transparent 22rem),
			var(--color-background);
	}

	.landing-hero__shell {
		position: relative;
		max-width: 1200px;
		min-height: clamp(30rem, 55vw, 36rem);
		margin: 0 auto;
		padding: 0 clamp(1.4rem, 4vw, 2rem);
		display: grid;
		align-items: center;
	}

	.landing-hero__content {
		position: relative;
		z-index: 3;
		width: min(33.5rem, 46vw);
	}

	.landing-hero__eyebrow {
		margin: 0 0 1rem;
		color: var(--color-primary);
		font-size: 0.75rem;
		font-weight: 800;
		letter-spacing: 0.14em;
		line-height: 1.3;
		text-transform: uppercase;
	}

	.landing-hero h1 {
		max-width: 9.5em;
		margin: 0;
		color: var(--color-bark);
		font-size: clamp(3rem, 6vw, 5.2rem);
		font-weight: 500;
		letter-spacing: 0;
		line-height: 0.98;
	}

	.landing-hero h1 span {
		color: var(--color-primary);
	}

	.landing-hero__lead {
		max-width: 27rem;
		margin: clamp(1.2rem, 2vw, 1.55rem) 0 0;
		color: var(--color-text-muted);
		font-size: clamp(0.98rem, 1.2vw, 1.1rem);
		font-weight: 500;
		line-height: 1.72;
	}

	.landing-hero__features {
		margin-top: clamp(1.6rem, 3vw, 2.2rem);
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: clamp(0.85rem, 2vw, 1.5rem);
		max-width: 29rem;
	}

	.landing-hero__feature {
		display: grid;
		justify-items: start;
		gap: 0.34rem;
		color: var(--color-bark);
		font-size: 0.8rem;
		line-height: 1.35;
	}

	.landing-hero__feature svg {
		width: 2rem;
		height: 2rem;
		margin-bottom: 0.14rem;
		color: var(--color-primary);
		stroke-width: 1.8;
	}

	.landing-hero__feature strong {
		font-size: 0.72rem;
		font-weight: 850;
		letter-spacing: 0.09em;
		text-transform: uppercase;
	}

	.landing-hero__feature span {
		max-width: 8rem;
		color: var(--color-text-muted);
	}

	.landing-hero__cta {
		width: fit-content;
		min-height: 3.9rem;
		margin-top: clamp(1.45rem, 3vw, 2rem);
		padding: 0 1.65rem 0 1.95rem;
		display: inline-flex;
		align-items: center;
		gap: 1rem;
		color: var(--color-surface);
		background: #5f6f3c;
		border-radius: 999px;
		font-size: 0.82rem;
		font-weight: 850;
		letter-spacing: 0.04em;
		text-decoration: none;
		text-transform: uppercase;
		box-shadow: 0 16px 34px rgba(75, 64, 56, 0.12);
	}

	.landing-hero__cta:hover {
		color: var(--color-surface);
		background: #536332;
		transform: translateY(-2px);
	}

	.landing-hero__cta svg {
		width: 1.05rem;
		height: 1.05rem;
		stroke-width: 2.4;
	}

	.landing-hero__dots {
		position: absolute;
		z-index: 1;
		right: min(44vw, 31rem);
		bottom: clamp(5.7rem, 10vw, 8.4rem);
		width: 8.1rem;
		height: 7.2rem;
		background-image: radial-gradient(circle, rgba(155, 135, 115, 0.3) 1.25px, transparent 1.35px);
		background-position: 0 0;
		background-size: 0.83rem 0.83rem;
		opacity: 0.85;
	}

	.landing-hero__media {
		position: absolute;
		z-index: 2;
		top: clamp(1.8rem, 4vw, 2.7rem);
		right: calc(50% - 50vw);
		width: min(58vw, 53rem);
		height: clamp(26rem, 44vw, 36rem);
		margin: 0;
		overflow: hidden;
		clip-path: polygon(30% 0, 100% 0, 100% 100%, 26% 100%, 0 55%);
	}

	.landing-hero__media::after {
		position: absolute;
		inset: 0;
		background: linear-gradient(90deg, rgba(75, 64, 56, 0.08), transparent 42%);
		content: "";
		pointer-events: none;
	}

	.landing-hero__media img {
		width: 100%;
		height: 100%;
		display: block;
		object-fit: cover;
		object-position: 49% 48%;
	}

	.categories-section {
		position: relative;
		padding: clamp(3.7rem, 7vw, 5.6rem) clamp(1.2rem, 4vw, 2rem) clamp(4.1rem, 7vw, 6.2rem);
		background: var(--color-background);
		overflow: hidden;
	}

	.categories-section::before {
		position: absolute;
		inset: 7% auto auto 50%;
		width: min(46rem, 86vw);
		height: min(46rem, 86vw);
		background: radial-gradient(circle, rgba(203, 183, 154, 0.22), transparent 64%);
		content: "";
		pointer-events: none;
		transform: translateX(-50%);
	}

	.categories-section__inner {
		position: relative;
		z-index: 1;
		max-width: 1100px;
		margin: 0 auto;
	}

	.categories-section__intro {
		max-width: 35rem;
		margin: 0 auto;
		text-align: center;
	}

	.categories-section__eyebrow {
		margin: 0 0 0.58rem;
		color: var(--color-primary);
		font-size: 0.68rem;
		font-weight: 850;
		letter-spacing: 0.15em;
		line-height: 1.3;
		text-transform: uppercase;
	}

	.categories-section h2 {
		margin: 0;
		color: var(--color-bark);
		font-size: clamp(2.05rem, 4vw, 3.35rem);
		font-weight: 500;
		letter-spacing: 0;
		line-height: 1.05;
	}

	.categories-section__intro p:last-child {
		max-width: 31rem;
		margin: 1rem auto 0;
		color: var(--color-text-muted);
		font-size: clamp(0.94rem, 1.4vw, 1.05rem);
		font-weight: 500;
		line-height: 1.65;
	}

	.categories-section__grid {
		margin-top: clamp(2.2rem, 5vw, 3.35rem);
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: clamp(1rem, 2.4vw, 1.55rem);
	}

	.category-card {
		position: relative;
		display: block;
		min-width: 0;
		color: var(--color-bark);
		background: rgba(255, 255, 255, 0.72);
		border: 1px solid rgba(222, 212, 198, 0.72);
		border-radius: 8px;
		box-shadow: 0 18px 38px rgba(75, 64, 56, 0.09);
		text-decoration: none;
		transition:
			box-shadow 180ms ease,
			transform 180ms ease;
	}

	.category-card:hover {
		color: var(--color-bark);
		box-shadow: 0 24px 48px rgba(75, 64, 56, 0.13);
		transform: translateY(-5px);
	}

	.category-card__image {
		aspect-ratio: 1.58 / 1;
		margin: 0.55rem 0.55rem 0;
		overflow: hidden;
		border-radius: 6px;
		background: var(--color-background-soft);
	}

	.category-card__image img {
		width: 100%;
		height: 100%;
		display: block;
		object-fit: cover;
		transition: transform 520ms ease;
	}

	.category-card:hover .category-card__image img {
		transform: scale(1.055);
	}

	.category-card__badge {
		position: absolute;
		top: 0.34rem;
		left: 0.38rem;
		width: 3.45rem;
		height: 3.45rem;
		display: grid;
		place-items: center;
		color: var(--color-surface);
		background: #6b7a4a;
		border: 1px solid rgba(255, 255, 255, 0.26);
		border-radius: 999px;
		box-shadow: 0 14px 26px rgba(75, 64, 56, 0.14);
	}

	.category-card__badge svg {
		width: 1.45rem;
		height: 1.45rem;
		stroke-width: 1.75;
	}

	.category-card__body {
		min-height: 4.6rem;
		padding: 1.05rem 1rem 1.08rem;
		display: flex;
		flex-direction: row;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
	}

	.category-card__body h3 {
		flex: 1 1 auto;
		min-width: 0;
		margin: 0;
		color: inherit;
		font-size: clamp(1rem, 1.8vw, 1.22rem);
		font-weight: 500;
		line-height: 1.2;
	}

	.category-card__body svg {
		width: 1.05rem;
		height: 1.05rem;
		flex: 0 0 auto;
		color: var(--color-bark);
		stroke-width: 2.1;
		transition: transform 180ms ease;
	}

	.category-card:hover .category-card__body svg {
		transform: translateX(4px);
	}

	@media (prefers-reduced-motion: no-preference) {
		.reveal-ready .categories-section__intro,
		.reveal-ready .category-card {
			opacity: 0;
			filter: blur(10px);
			transform: translateY(2rem);
		}

		.reveal-ready .categories-section.is-visible .categories-section__intro {
			animation: categories-intro-in 720ms cubic-bezier(0.2, 0.8, 0.2, 1) forwards;
		}

		.reveal-ready .categories-section.is-visible .category-card {
			animation: category-card-in 760ms cubic-bezier(0.16, 1, 0.3, 1) forwards;
			animation-delay: calc(120ms + (var(--card-index) * 85ms));
		}
	}

	@keyframes categories-intro-in {
		to {
			opacity: 1;
			filter: blur(0);
			transform: translateY(0);
		}
	}

	@keyframes category-card-in {
		0% {
			opacity: 0;
			filter: blur(12px);
			transform: translateY(2.25rem) scale(0.96);
		}

		62% {
			opacity: 1;
			filter: blur(0);
			transform: translateY(-0.2rem) scale(1.01);
		}

		100% {
			opacity: 1;
			filter: blur(0);
			transform: translateY(0) scale(1);
		}
	}

	@media (max-width: 960px) {
		.landing-hero {
			min-height: clamp(33rem, 68vw, 38rem);
			padding: clamp(2.7rem, 5vw, 4rem) 0 clamp(3rem, 5vw, 4.4rem);
		}

		.landing-hero__shell {
			min-height: clamp(27.5rem, 58vw, 32rem);
			display: grid;
			align-items: center;
			gap: 0;
		}

		.landing-hero__content {
			width: min(34rem, 58vw);
			max-width: none;
		}

		.landing-hero__media {
			position: absolute;
			top: clamp(7rem, 17vw, 9.4rem);
			right: clamp(-6.25rem, -10vw, -4rem);
			width: min(46vw, 30rem);
			height: clamp(16.5rem, 37vw, 22rem);
			clip-path: polygon(30% 0, 100% 0, 100% 100%, 27% 100%, 0 56%);
		}

		.landing-hero__dots {
			right: clamp(1.2rem, 5vw, 3rem);
			bottom: clamp(17rem, 46vw, 24rem);
		}

		.categories-section__grid {
			grid-template-columns: repeat(2, minmax(0, 1fr));
		}
	}

	@media (max-width: 640px) {
		.landing-hero {
			min-height: 26.9rem;
			padding: 1.45rem 0 1.65rem;
		}

		.landing-hero__shell {
			position: relative;
			min-height: 23.8rem;
			display: block;
			padding-inline: 1.2rem;
		}

		.landing-hero__content {
			width: min(64vw, 15.7rem);
			max-width: none;
		}

		.landing-hero__eyebrow {
			margin-bottom: 0.62rem;
			font-size: 0.6rem;
		}

		.landing-hero h1 {
			max-width: 7.5em;
			font-size: clamp(1.95rem, 8.7vw, 2.65rem);
			line-height: 1.01;
		}

		.landing-hero__lead {
			max-width: 13.6rem;
			margin-top: 0.85rem;
			font-size: 0.78rem;
			line-height: 1.48;
		}

		.landing-hero__features {
			grid-template-columns: repeat(3, minmax(0, 1fr));
			gap: 0.48rem;
			width: min(64vw, 15.7rem);
			max-width: none;
			margin-top: 1rem;
		}

		.landing-hero__feature {
			font-size: 0.62rem;
		}

		.landing-hero__feature svg {
			width: 1.45rem;
			height: 1.45rem;
		}

		.landing-hero__feature strong {
			font-size: 0.53rem;
		}

		.landing-hero__cta {
			min-height: 2.85rem;
			margin-top: 1.1rem;
			padding-inline: 1.25rem 1.05rem;
			font-size: 0.68rem;
		}

		.landing-hero__media {
			position: absolute;
			top: clamp(5.7rem, 22vw, 6.45rem);
			right: clamp(-12.8rem, -45vw, -10.6rem);
			width: clamp(17rem, 78vw, 21rem);
			height: clamp(16.8rem, 68vw, 18.8rem);
			clip-path: polygon(30% 0, 100% 0, 100% 100%, 27% 100%, 0 56%);
		}

		.landing-hero__dots {
			right: clamp(1.05rem, 8vw, 2.1rem);
			bottom: 6.9rem;
			width: 4.8rem;
			height: 4.4rem;
			background-size: 0.64rem 0.64rem;
		}

		.categories-section {
			padding: 3rem 0.9rem 3.6rem;
		}

		.categories-section__intro {
			max-width: 21rem;
		}

		.categories-section__grid {
			grid-template-columns: repeat(2, minmax(0, 1fr));
			gap: 0.7rem;
			max-width: 23rem;
			margin-inline: auto;
		}

		.category-card {
			border-radius: 7px;
			box-shadow: 0 12px 24px rgba(75, 64, 56, 0.08);
		}

		.category-card__image {
			aspect-ratio: 1.45 / 1;
			margin: 0.38rem 0.38rem 0;
			border-radius: 5px;
		}

		.category-card__badge {
			top: 0.18rem;
			left: 0.18rem;
			width: 2.35rem;
			height: 2.35rem;
		}

		.category-card__badge svg {
			width: 1.05rem;
			height: 1.05rem;
		}

		.category-card__body {
			min-height: 3.05rem;
			padding: 0.58rem 0.5rem 0.62rem;
			gap: 0.45rem;
		}

		.category-card__body h3 {
			font-size: clamp(0.72rem, 3.7vw, 0.86rem);
			line-height: 1.12;
		}

		.category-card__body svg {
			width: 0.82rem;
			height: 0.82rem;
		}
	}
</style>

<script>
	const revealSection = document.querySelector('[data-reveal-section]');

	if (revealSection && !window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
		document.documentElement.classList.add('reveal-ready');

		const revealObserver = new IntersectionObserver(
			(entries, observer) => {
				for (const entry of entries) {
					if (!entry.isIntersecting) continue;
					entry.target.classList.add('is-visible');
					observer.unobserve(entry.target);
				}
			},
			{ rootMargin: '0px 0px -18% 0px', threshold: 0.2 },
		);

		revealObserver.observe(revealSection);
	}
</script>
