<script>
	const revealSection = document.querySelector('[data-reveal-section]');
	const contactFormShell = document.querySelector('[data-contact-form-shell]');
	const contactFormToggle = document.querySelector('[data-contact-form-toggle]');
	const contactFormToggleLabel = document.querySelector('[data-contact-form-toggle-label]');
	const contactFormPanel = document.querySelector('#contact-form-panel');
	const contactFormMobileQuery = window.matchMedia('(max-width: 640px)');

	const updateContactFormState = () => {
		if (
			!(contactFormShell instanceof HTMLElement) ||
			!(contactFormToggle instanceof HTMLElement) ||
			!(contactFormPanel instanceof HTMLElement)
		) {
			return;
		}

		const isMobile = contactFormMobileQuery.matches;
		const isOpen = contactFormShell.classList.contains('is-open');
		const shouldCollapse = isMobile && !isOpen;
		const openLabel = contactFormToggle.getAttribute('data-open-label') ?? 'Aizpildīt pieteikumu';
		const closeLabel = contactFormToggle.getAttribute('data-close-label') ?? 'Paslēpt formu';

		contactFormToggle.setAttribute('aria-expanded', String(isMobile && isOpen));
		contactFormPanel.toggleAttribute('inert', shouldCollapse);

		if (contactFormToggleLabel instanceof HTMLElement) {
			contactFormToggleLabel.textContent = isOpen ? closeLabel : openLabel;
		}
	};

	contactFormToggle?.addEventListener('click', () => {
		contactFormShell?.classList.toggle('is-open');
		updateContactFormState();
	});

	contactFormMobileQuery.addEventListener('change', () => {
		if (!contactFormMobileQuery.matches) {
			contactFormShell?.classList.add('is-open');
		} else {
			contactFormShell?.classList.remove('is-open');
		}

		updateContactFormState();
	});

	if (!contactFormMobileQuery.matches) {
		contactFormShell?.classList.add('is-open');
	}

	updateContactFormState();

	if (revealSection && !window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
		document.documentElement.classList.add('reveal-ready');

		const revealObserver = new IntersectionObserver(
			(entries, observer) => {
				for (const entry of entries) {
					if (!entry.isIntersecting) continue;
					entry.target.classList.add('is-visible');
					observer.unobserve(entry.target);
				}
			},
			{ rootMargin: '0px 0px -18% 0px', threshold: 0.2 },
		);

		revealObserver.observe(revealSection);
	}
</script>
