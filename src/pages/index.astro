---
import ArrowRight from '@lucide/astro/icons/arrow-right';
import Award from '@lucide/astro/icons/award';
import BaseLayout from '../layouts/BaseLayout.astro';
import CalendarDays from '@lucide/astro/icons/calendar-days';
import ChevronDown from '@lucide/astro/icons/chevron-down';
import FloatingActions from '../components/common/FloatingActions.astro';
import Mail from '@lucide/astro/icons/mail';
import MapPin from '@lucide/astro/icons/map-pin';
import MessageCircle from '@lucide/astro/icons/message-circle';
import PackageCheck from '@lucide/astro/icons/package-check';
import Phone from '@lucide/astro/icons/phone';
import ScrollToTop from '../components/common/ScrollToTop.astro';
import Send from '@lucide/astro/icons/send';
import ShieldCheck from '@lucide/astro/icons/shield-check';
import SiteFooter from '../components/common/SiteFooter.astro';
import SiteHeader from '../components/common/SiteHeader.astro';
import Truck from '@lucide/astro/icons/truck';
import UserRound from '@lucide/astro/icons/user-round';
import hugeIcons from '@iconify-json/hugeicons/icons.json';

const heroImage = '/images/landing-tent-pic.svg';

const heroFeatures = [
	{
		description: 'Pārbaudīts inventārs',
		icon: Award,
		label: 'Kvalitāte',
	},
	{
		description: 'Piegādājam un uzstādām',
		icon: Truck,
		label: 'Piegāde',
	},
	{
		description: 'Pieredze un atbildība',
		icon: ShieldCheck,
		label: 'Uzticami',
	},
];

type IconifyIcon = {
	body: string;
	height?: number;
	width?: number;
};

const hugeIconSet = hugeIcons as {
	height: number;
	icons: Record<string, IconifyIcon>;
	width: number;
};

const getHugeIcon = (name: string) => {
	const icon = hugeIconSet.icons[name];

	if (!icon) {
		throw new Error(`Missing Huge Icons symbol: ${name}`);
	}

	return {
		body: icon.body,
		height: icon.height ?? hugeIconSet.height,
		width: icon.width ?? hugeIconSet.width,
	};
};

const customCategoryIcons = {
	beanBag: {
		body: `
			<g fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.45">
				<path d="M7.1 20.25h9.8c2.08 0 3.45-1.42 3.15-3.48C19.36 11.93 16.63 6.5 12 6.5s-7.36 5.43-8.05 10.27c-.3 2.06 1.07 3.48 3.15 3.48Z" />
				<path d="M8.15 18.05c1.7-.8 5.99-.8 7.7 0" />
				<path d="M9.1 8.75c1.42 1.02 4.38 1.02 5.8 0" />
				<path d="M12 6.75v11.1" />
			</g>
		`,
		height: 24,
		width: 24,
	},
	eventTent: {
		body: `
			<g fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.45">
				<path d="M2.75 10.25h18.5L17.5 5.5h-11l-3.75 4.75Z" />
				<path d="M5 10.25v9.25" />
				<path d="M9.65 10.25v9.25" />
				<path d="M14.35 10.25v9.25" />
				<path d="M19 10.25v9.25" />
				<path d="M3.75 19.5h16.5" />
				<path d="M7.8 10.25l2-4.75" />
				<path d="M12 10.25V5.5" />
				<path d="M16.2 10.25l-2-4.75" />
			</g>
		`,
		height: 24,
		width: 24,
	},
};

const categoryItems = [
	{
		alt: 'Balta pasākumu telts plašā zālienā',
		href: '/teltis',
		icon: customCategoryIcons.eventTent,
		image:
			'https://images.unsplash.com/photo-1675376616537-c8aa9ddc9977?auto=format&fit=crop&ixlib=rb-4.1.0&q=80&w=900',
		title: 'Teltis',
	},
	{
		alt: 'Pasākumu telts interjers ar grīdas segumu un gaismām',
		href: '/gridas-segumi',
		icon: getHugeIcon('floor-plan'),
		image:
			'https://images.unsplash.com/photo-1724125082683-49b0e812046f?q=80&w=1335&auto=format&fit=crop&ixlib=rb-4.1.0&q=80&w=900',
		title: 'Grīdas segumi',
	},
	{
		alt: 'Āra pasākuma zona ar baltiem krēsliem un galdiem',
		href: '/galdi-un-kresli',
		icon: getHugeIcon('dining-table'),
		image:
			'https://images.unsplash.com/photo-1618055620740-24c9cf2305e5?q=80&w=1170&auto=format&fit=crop&ixlib=rb-4.1.0&q=80&w=900',
		title: 'Galdi un krēsli',
	},
	{
		alt: 'Iedegts āra sildītājs vakara pasākumā',
		href: '/ara-silditaji',
		icon: getHugeIcon('heater'),
		image:
			'https://images.unsplash.com/photo-1779249245434-9c4fec8aebed?q=80&w=735&auto=format&fit=crop&ixlib=rb-4.1.0&q=80&w=900',
		title: 'Āra sildītāji',
	},
	{
		alt: 'Āra atpūtas zona ar mīkstām sēdvietām',
		href: '/pufi',
		icon: customCategoryIcons.beanBag,
		image:
			'https://images.unsplash.com/photo-1776008107357-0c18d761ca72?q=80&w=1170&auto=format&fit=crop&ixlib=rb-4.1.0&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D',
		title: 'Pufi',
	},
	{
		alt: 'Pasākuma galda dekori ar svecēm un aksesuāriem',
		href: '#kontakti',
		icon: getHugeIcon('balloons'),
		image:
			'https://images.unsplash.com/photo-1519225421980-715cb0215aed?auto=format&fit=crop&ixlib=rb-4.1.0&q=80&w=900',
		title: 'Pasākumu aksesuāri',
	},
];

const contactLinks = [
	{
		href: 'tel:+37129373231',
		icon: Phone,
		label: 'Zvaniet',
		value: '+371 29 373 231',
	},
	{
		href: 'mailto:info@liepajasteltis.lv',
		icon: Mail,
		label: 'E-pasts',
		value: 'info@liepajasteltis.lv',
	},
	{
		href: '#kontakti',
		icon: MapPin,
		label: 'Bāze',
		value: 'Liepāja - visa Latvija',
	},
];

---

<BaseLayout>
	<SiteHeader />
	<main id="top" class="page-shell" aria-label="Liepājas Teltis">
		<FloatingActions />
		<ScrollToTop />
		<section class="landing-hero" aria-labelledby="landing-hero-title" data-reveal="up">
			<div class="landing-hero__shell">
				<div class="landing-hero__content">
					<p class="landing-hero__eyebrow">Telšu noma Liepājā un visā Latvijā</p>
					<h1 id="landing-hero-title">
						<span class="landing-hero__title-accent">Radām vietu</span>
						<span class="landing-hero__title-rest">īpašiem mirkļiem</span>
					</h1>
					<p class="landing-hero__lead">
						Kvalitatīvas teltis un inventārs jebkuram pasākumam - no nelielām svinībām līdz lieliem
						notikumiem.
					</p>

					<div class="landing-hero__features" aria-label="Pakalpojuma priekšrocības">
						{
							heroFeatures.map(({ description, icon: Icon, label }) => (
								<article class="landing-hero__feature">
									<Icon aria-hidden="true" />
									<strong>{label}</strong>
									<span>{description}</span>
								</article>
							))
						}
					</div>

					<a class="landing-hero__cta" href="/pieteikt-nomu">
						<span>Pieteikt nomu</span>
						<ArrowRight aria-hidden="true" />
					</a>
				</div>

				<figure class="landing-hero__media" aria-label="Pasākumu telts piemērs">
					<img
						alt="Balta pasākumu telts ar dekoratīvām gaismām zaļā ārtelpā"
						decoding="async"
						fetchpriority="high"
						src={heroImage}
					/>
				</figure>
			</div>
		</section>

		<section class="categories-section" id="kategorijas" aria-labelledby="categories-title" data-reveal-section data-reveal="up">
			<div class="categories-section__inner">
				<div class="categories-section__intro">
					<p class="categories-section__eyebrow">Kategorijas</p>
					<h2 id="categories-title">Nomas inventārs</h2>
					<p>
						Piedāvājam plašu inventāra klāstu, lai jūsu pasākums būtu izdevies līdz pēdējam sīkumam.
					</p>
				</div>

				<div class="categories-section__grid" aria-label="Nomas inventāra kategorijas">
					{
						categoryItems.map(({ alt, href, icon, image, title }, index) => (
							<a class="card category-card" href={href} style={`--card-index: ${index};`} aria-label={`${title} - pieteikt nomu`}>
								<figure class="category-card__image">
									<img alt={alt} decoding="async" loading="lazy" src={image} />
								</figure>
								<span class="category-card__badge" aria-hidden="true">
									<svg aria-hidden="true" viewBox={`0 0 ${icon.width} ${icon.height}`} set:html={icon.body} />
								</span>
								<div class="card-body category-card__body">
									<h3 class="card-title">{title}</h3>
									<ArrowRight aria-hidden="true" />
								</div>
							</a>
						))
					}
				</div>
			</div>
		</section>

		<section class="contact-section" id="pieteikums" aria-labelledby="contact-title" data-reveal="left">
			<div class="contact-section__inner">
				<div class="contact-section__info">
					<div>
						<p class="contact-section__eyebrow">Sazināties</p>
						<h2 id="contact-title">Pastāstiet par savu <span>pasākumu</span></h2>
						<p class="contact-section__lead">
							Aizpildiet pieteikuma formu vai zvaniet - atbildēsim 24 stundu laikā ar piedāvājumu, kas
							pielāgots jūsu svinībām.
						</p>
					</div>

					<div class="contact-section__links" aria-label="Kontaktinformācija">
						{
							contactLinks.map(({ href, icon: Icon, label, value }) => (
								<a href={href} class="contact-link">
									<span class="contact-link__icon">
										<Icon aria-hidden="true" />
									</span>
									<span>
										<strong>{label}</strong>
										<span>{value}</span>
									</span>
								</a>
							))
						}
					</div>
				</div>

				<div class="contact-form-shell" data-contact-form-shell>
					<button
						class="contact-form-toggle"
						type="button"
						aria-expanded="false"
						aria-controls="contact-form-panel"
						data-contact-form-toggle
						data-open-label="Aizpildīt pieteikumu"
						data-close-label="Paslēpt formu"
					>
						<span data-contact-form-toggle-label>Aizpildīt pieteikumu</span>
						<ChevronDown aria-hidden="true" />
					</button>

					<form class="contact-form" id="contact-form-panel" name="noma-pieteikums" method="post" data-netlify="true">
						<input type="hidden" name="form-name" value="noma-pieteikums" />

						<fieldset class="fieldset contact-form__field">
							<label class="fieldset-legend" for="contact-name">Vārds, uzvārds</label>
							<div class="contact-form__control">
								<UserRound aria-hidden="true" />
								<input
									class="input contact-form__input"
									id="contact-name"
									name="vards_uzvards"
									type="text"
									autocomplete="name"
									required
								/>
							</div>
						</fieldset>

						<fieldset class="fieldset contact-form__field">
							<label class="fieldset-legend" for="contact-phone">Telefona numurs</label>
							<div class="contact-form__control">
								<Phone aria-hidden="true" />
								<input
									class="input contact-form__input"
									id="contact-phone"
									name="telefona_numurs"
									type="tel"
									autocomplete="tel"
									required
								/>
							</div>
						</fieldset>

						<fieldset class="fieldset contact-form__field contact-form__field--full">
							<label class="fieldset-legend" for="contact-email">Epasts</label>
							<div class="contact-form__control">
								<Mail aria-hidden="true" />
								<input
									class="input contact-form__input"
									id="contact-email"
									name="epasts"
									type="email"
									autocomplete="email"
									required
								/>
							</div>
						</fieldset>

						<fieldset class="fieldset contact-form__field">
							<label class="fieldset-legend" for="contact-date">Pasākuma datums</label>
							<div class="contact-form__control contact-form__control--date">
								<CalendarDays aria-hidden="true" />
								<input class="input contact-form__input" id="contact-date" name="pasakuma_datums" type="date" required />
							</div>
						</fieldset>

						<fieldset class="fieldset contact-form__field">
							<label class="fieldset-legend" for="contact-location">Pasākuma norises vieta</label>
							<div class="contact-form__control">
								<MapPin aria-hidden="true" />
								<input
									class="input contact-form__input"
									id="contact-location"
									name="pasakuma_norises_vieta"
									type="text"
									required
								/>
							</div>
						</fieldset>

						<fieldset class="fieldset contact-form__field contact-form__field--full">
							<label class="fieldset-legend" for="contact-inventory">Vēlamais inventārs</label>
							<div class="contact-form__control contact-form__control--textarea">
								<PackageCheck aria-hidden="true" />
								<textarea
									class="textarea contact-form__textarea"
									id="contact-inventory"
									name="velamais_inventars"
									rows="5"
									required
								></textarea>
							</div>
						</fieldset>

						<div class="contact-form__footer">
							<p>
								Nosūtot formu, piekrītat, ka sazināsimies par jūsu pieteikumu. Plašāk:
								<a href="/privatuma-politika">privātuma politika</a>.
							</p>
							<button class="btn contact-form__button" type="submit">
								<span>Nosūtīt pieteikumu</span>
								<Send aria-hidden="true" />
							</button>
						</div>
					</form>
				</div>
			</div>
		</section>
	</main>
	<SiteFooter />
</BaseLayout>

<style>
	:global(.site-header) {
		background: transparent;
	}

	.landing-hero {
		--hero-art-height: clamp(56rem, 73.4vw, 88rem);
		--hero-art-width: clamp(60rem, 76.8vw, 92rem);
		--hero-art-x: clamp(10rem, 23.4vw, 28rem);
		--hero-art-y: clamp(-8rem, -6.7vw, -4rem);
		--hero-lift: clamp(7.25rem, 12.5vw, 15rem);
		--hero-text-gap: clamp(5.2rem, 5.6vw, 6.2rem);
		position: relative;
		min-height: clamp(45rem, 62vw, 51rem);
		margin-top: calc(var(--hero-lift) * -1);
		padding: calc(var(--hero-lift) + var(--hero-text-gap)) 0 clamp(2.4rem, 4vw, 3.4rem);
		overflow: hidden;
		background: var(--color-background);
	}

	.landing-hero__shell {
		position: static;
		max-width: 1200px;
		min-height: clamp(34rem, 48vw, 39rem);
		margin: 0 auto;
		padding: 0 clamp(1.65rem, 4.4vw, 2.5rem);
		display: grid;
		align-items: center;
		overflow: visible;
	}

	.landing-hero__content {
		position: relative;
		z-index: 3;
		width: min(42rem, 48vw);
		padding-top: clamp(0.25rem, 1.8vw, 1.15rem);
		transform: translateY(clamp(-4rem, -4.1vw, -2.4rem));
	}

	.landing-hero__eyebrow {
		margin: 0 0 1rem;
		color: #8A9271;
		font-size: 0.75rem;
		font-weight: 800;
		letter-spacing: 0.14em;
		line-height: 1.3;
		text-transform: uppercase;
	}

	.landing-hero h1 {
		max-width: 11.2em;
		margin: 0;
		color: var(--color-bark);
		font-family: Georgia, "Times New Roman", serif;
		font-size: clamp(3.25rem, 5.15vw, 5.05rem);
		font-weight: 500;
		letter-spacing: 0;
		line-height: 0.96;
	}

	.landing-hero__title-accent {
		color: var(--color-primary);
	}

	.landing-hero__title-accent,
	.landing-hero__title-rest {
		display: block;
	}

	.landing-hero__title-rest {
		color: var(--color-bark);
		white-space: nowrap;
	}

	.landing-hero__lead {
		max-width: 27rem;
		margin: clamp(1.2rem, 2vw, 1.55rem) 0 0;
		color: var(--color-text-muted);
		font-size: clamp(0.98rem, 1.2vw, 1.1rem);
		font-weight: 500;
		line-height: 1.72;
	}

	.landing-hero__features {
		margin-top: clamp(1.6rem, 3vw, 2.2rem);
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: clamp(0.85rem, 2vw, 1.5rem);
		max-width: 29rem;
	}

	.landing-hero__feature {
		display: grid;
		justify-items: start;
		gap: 0.34rem;
		color: var(--color-bark);
		font-size: 0.8rem;
		line-height: 1.35;
	}

	.landing-hero__feature svg {
		width: 2rem;
		height: 2rem;
		margin-bottom: 0.14rem;
		color: var(--color-primary);
		stroke-width: 1.8;
	}

	.landing-hero__feature strong {
		font-size: 0.72rem;
		font-weight: 850;
		letter-spacing: 0.09em;
		text-transform: uppercase;
	}

	.landing-hero__feature span {
		max-width: 8rem;
		color: var(--color-text-muted);
	}

	.landing-hero__cta {
		width: fit-content;
		min-height: 3.9rem;
		margin-top: clamp(1.45rem, 3vw, 2rem);
		padding: 0 1.65rem 0 1.95rem;
		display: inline-flex;
		align-items: center;
		gap: 1rem;
		color: var(--color-surface);
		background: #5f6f3c;
		border-radius: 999px;
		font-size: 0.82rem;
		font-weight: 640;
		letter-spacing: 0.04em;
		text-decoration: none;
		text-transform: uppercase;
		box-shadow: 0 16px 34px rgba(75, 64, 56, 0.12);
	}

	.landing-hero__cta:hover {
		color: var(--color-surface);
		background: #536332;
		transform: translateY(-2px);
	}

	.landing-hero__cta svg {
		width: 1.05rem;
		height: 1.05rem;
		stroke-width: 1.6;
	}

	.landing-hero__media {
		position: absolute;
		z-index: 1;
		top: 0;
		left: 0;
		width: 100vw;
		height: calc(100% + 12rem);
		margin: 0;
		overflow: hidden;
	}

	.landing-hero__media::after {
		position: absolute;
		right: 0;
		bottom: 0;
		left: 0;
		height: 15rem;
		background: linear-gradient(180deg, rgba(246, 241, 231, 0), var(--color-background) 78%);
		content: "";
		pointer-events: none;
	}

	.landing-hero__media img {
		width: var(--hero-art-width);
		height: var(--hero-art-height);
		min-height: 100%;
		display: block;
		max-width: none;
		object-fit: contain;
		object-position: left center;
		transform: translate(var(--hero-art-x), var(--hero-art-y));
	}

	.categories-section {
		position: relative;
		padding: clamp(3.7rem, 7vw, 5.6rem) clamp(1.2rem, 4vw, 2rem) clamp(4.1rem, 7vw, 6.2rem);
		background: var(--color-background);
		overflow: hidden;
	}

	.categories-section::before {
		position: absolute;
		inset: 7% auto auto 50%;
		width: min(46rem, 86vw);
		height: min(46rem, 86vw);
		background: radial-gradient(circle, rgba(203, 183, 154, 0.22), transparent 64%);
		content: "";
		pointer-events: none;
		transform: translateX(-50%);
	}

	.categories-section::after {
		position: absolute;
		left: max(1.2rem, calc(50% - 39rem));
		top: clamp(7rem, 15vw, 12rem);
		width: clamp(8rem, 18vw, 13rem);
		height: clamp(6rem, 12vw, 9rem);
		background-image: radial-gradient(circle, rgba(155, 135, 115, 0.32) 1.25px, transparent 1.5px);
		background-size: 0.78rem 0.78rem;
		content: "";
		opacity: 0.72;
		pointer-events: none;
	}

	.categories-section__inner {
		position: relative;
		z-index: 1;
		max-width: 1100px;
		margin: 0 auto;
	}

	.categories-section__intro {
		max-width: 35rem;
		margin: 0 auto;
		text-align: center;
	}

	.categories-section__eyebrow {
		margin: 0 0 0.58rem;
		color: #8A9271;
		font-size: 0.68rem;
		font-weight: 850;
		letter-spacing: 0.15em;
		line-height: 1.3;
		text-transform: uppercase;
	}

	.categories-section h2 {
		margin: 0;
		color: var(--color-bark);
		font-size: clamp(2.05rem, 4vw, 3.35rem);
		font-weight: 500;
		letter-spacing: 0;
		line-height: 1.05;
	}

	.categories-section__intro p:last-child {
		max-width: 31rem;
		margin: 1rem auto 0;
		color: var(--color-text-muted);
		font-size: clamp(0.94rem, 1.4vw, 1.05rem);
		font-weight: 500;
		line-height: 1.65;
	}

	.categories-section__grid {
		margin-top: clamp(2.2rem, 5vw, 3.35rem);
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: clamp(1rem, 2.4vw, 1.55rem);
	}

	.category-card {
