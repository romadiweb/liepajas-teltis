---
import '../styles/global.css';
import CartDrawer from '../components/common/CartDrawer.astro';
import CookieConsent from '../components/CookieConsent.astro';
import ScrollAnimations from '../components/common/ScrollAnimations.astro';

interface Props {
	title?: string;
	description?: string;
	resetScrollOnLoad?: boolean;
}

const {
	title = 'Liepājas Teltis',
	description = 'Pasākumu telšu un inventāra noma Liepājā.',
	resetScrollOnLoad = false,
} = Astro.props;
---

<!doctype html>
<html lang="lv">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="description" content={description} />
		<meta name="generator" content={Astro.generator} />
		<script
			is:inline
			set:html={`(() => {
				try {
					if (!window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
						document.documentElement.classList.add('motion-preload');
					}
				} catch {
					document.documentElement.classList.add('motion-preload');
				}
			})();`}
		/>
		<title>{title}</title>
		{
			resetScrollOnLoad && (
				<script
					is:inline
					set:html={`(() => {
						if (window.location.hash) return;
						if ('scrollRestoration' in history) history.scrollRestoration = 'manual';
						window.scrollTo(0, 0);
						window.addEventListener('pageshow', () => {
							if (!window.location.hash) requestAnimationFrame(() => window.scrollTo(0, 0));
						});
					})();`}
				/>
			)
		}
	</head>

	<body>
		<slot />

		<CartDrawer />
		<CookieConsent />
		<ScrollAnimations />
	</body>
</html>
