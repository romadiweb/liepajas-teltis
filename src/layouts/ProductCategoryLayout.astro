---
import ArrowRight from '@lucide/astro/icons/arrow-right';
import ChevronDown from '@lucide/astro/icons/chevron-down';
import ChevronLeft from '@lucide/astro/icons/chevron-left';
import ChevronRight from '@lucide/astro/icons/chevron-right';
import Clock3 from '@lucide/astro/icons/clock-3';
import Euro from '@lucide/astro/icons/euro';
import Maximize2 from '@lucide/astro/icons/maximize-2';
import MessageCircleQuestionMark from '@lucide/astro/icons/message-circle-question-mark';
import Ruler from '@lucide/astro/icons/ruler';
import RulerDimensionLine from '@lucide/astro/icons/ruler-dimension-line';
import ShoppingBag from '@lucide/astro/icons/shopping-bag';
import UserRound from '@lucide/astro/icons/user-round';
import Users from '@lucide/astro/icons/users';
import X from '@lucide/astro/icons/x';
import BaseLayout from './BaseLayout.astro';
import FloatingActions from '../components/common/FloatingActions.astro';
import ScrollToTop from '../components/common/ScrollToTop.astro';
import SiteFooter from '../components/common/SiteFooter.astro';
import SiteHeader from '../components/common/SiteHeader.astro';

type FilterItem = {
	active?: boolean;
	label: string;
};

type ProductItem = {
	additionalInfo?: string;
	badge?: string;
	capacity: string;
	category: string;
	description?: string;
	galleryImages: string[];
	href?: string;
	id: string;
	image: string;
	installTime: string;
	priceCents: number;
	size: string;
	title: string;
	variant?: string;
};

interface Props {
	breadcrumbCurrent: string;
	description: string;
	filters: FilterItem[];
	products: ProductItem[];
	title: string;
}

const { breadcrumbCurrent, description, filters, products, title } = Astro.props;
const allFilterLabel = filters[0]?.label;
const sizeOptions = Array.from(new Set(products.map((product) => product.size).filter(Boolean))).sort((first, second) =>
	first.localeCompare(second, 'lv'),
);
const modalProducts = products.map((product) => ({
	additionalInfo: product.additionalInfo ?? '',
	capacity: product.capacity,
	category: product.category,
	description: product.description ?? '',
	galleryImages: product.galleryImages.length > 0 ? product.galleryImages : [product.image],
	href: product.href ?? '#kontakti',
	id: product.id,
	image: product.image,
	installTime: product.installTime,
	priceCents: product.priceCents,
	size: product.size,
	title: product.title,
	variant: product.variant ?? '',
}));
---

<BaseLayout title={`${title} | Liepājas teltis`} description={description}>
	<div class="page-shell product-page">
		<SiteHeader />
		<main class="product-category" aria-labelledby="product-category-title">
			<section class="product-category__hero">
				<nav class="product-category__breadcrumbs" aria-label="Lapas ceļš">
					<a href="/">Sākums</a>
					<ChevronRight aria-hidden="true" />
					<span>{breadcrumbCurrent}</span>
				</nav>

				<div class="product-category__intro">
					<div>
						<h1 id="product-category-title">{title}</h1>
						<p>{description}</p>
					</div>
					<div class="product-category__intro-actions">
						<a class="product-category__help" href="#kontakti">
							<MessageCircleQuestionMark aria-hidden="true" />
							<span>
								<strong>Nepieciešama palīdzība?</strong>
								<span>Sazinies ar mums</span>
							</span>
						</a>
						<label class="product-category__size-filter product-category__size-filter--mobile">
							<Ruler aria-hidden="true" />
							<select data-product-size-filter aria-label="Filtrēt pēc izmēra">
								<option value="all">Visi izmēri</option>
								{sizeOptions.map((size) => <option value={size}>{size}</option>)}
							</select>
							<ChevronDown aria-hidden="true" />
						</label>
					</div>
				</div>
			</section>

			<section class="product-category__controls" aria-label="Produktu filtri">
				<div class="product-category__tabs">
					{
						filters.map((filter) => (
							<button
								aria-pressed={filter.active ? 'true' : 'false'}
								class:list={['product-category__tab', { 'is-active': filter.active }]}
								data-product-filter={filter.label === allFilterLabel ? 'all' : filter.label}
								type="button"
							>
								{filter.label}
							</button>
						))
					}
				</div>
				<label class="product-category__size-filter product-category__size-filter--desktop">
					<Ruler aria-hidden="true" />
					<select data-product-size-filter aria-label="Filtrēt pēc izmēra">
						<option value="all">Visi izmēri</option>
						{sizeOptions.map((size) => <option value={size}>{size}</option>)}
					</select>
					<ChevronDown aria-hidden="true" />
				</label>
			</section>

			<section class="product-category__grid" aria-label={`${title} piedāvājums`}>
				{
					products.map((product, index) => (
						<article
							aria-label={`Atvērt informāciju: ${product.title}`}
							class="product-card"
							data-product-category={product.category}
							data-product-open={index}
							data-product-size={product.size}
							role="button"
							tabindex="0"
						>
							<div class="product-card__media">
								{product.badge && <span class="product-card__badge">{product.badge}</span>}
								<img src={product.image} alt={product.title} loading="lazy" />
							</div>
							<div class="product-card__body">
								<h2>{product.title}</h2>
								<div class="product-card__meta">
									<span>{product.category}</span>
									<span>{product.size}</span>
								</div>
								<ul>
									<li>
										<Users aria-hidden="true" />
										<span>{product.capacity}</span>
									</li>
									<li>
										<Clock3 aria-hidden="true" />
										<span>{product.installTime}</span>
									</li>
								</ul>
								<span class="product-card__button">
									<span>Skatīt vairāk</span>
									<ArrowRight aria-hidden="true" />
								</span>
							</div>
						</article>
					))
				}
			</section>

			<section class="product-category__cta" aria-label="Pieteikt citu telts izmēru">
				<div class="product-category__cta-icon">
					<RulerDimensionLine aria-hidden="true" />
				</div>
				<div>
					<h2>Neatradi piemērotu izmēru?</h2>
					<p>Piedāvājam teltis dažādos izmēros un konfigurācijās. Sazinies ar mums - palīdzēsim atrast labāko risinājumu.</p>
				</div>
				<a href="#kontakti">
					<span>Sazināties</span>
					<ArrowRight aria-hidden="true" />
				</a>
			</section>
		</main>
		<div class="product-modal" data-product-modal hidden role="dialog" aria-modal="true" aria-labelledby="product-modal-title">
			<button class="product-modal__backdrop" data-product-modal-close type="button" aria-label="Aizvērt produkta aprakstu"></button>
			<section class="product-modal__window" tabindex="-1">
				<button class="product-modal__close" data-product-modal-close type="button" aria-label="Aizvērt">
					<X aria-hidden="true" />
				</button>
				<div class="product-modal__media">
					<div class="product-modal__image-stage" data-product-modal-image-stage>
					<img data-product-modal-image src="" alt="" />
					<button class="product-modal__image-button product-modal__image-button--prev" data-product-modal-prev type="button" aria-label="Iepriekšējais attēls">
						<ChevronLeft aria-hidden="true" />
					</button>
					<button class="product-modal__image-button product-modal__image-button--next" data-product-modal-next type="button" aria-label="Nākamais attēls">
						<ChevronRight aria-hidden="true" />
					</button>
					<button class="product-modal__fullscreen-button" data-product-modal-fullscreen-open type="button" aria-label="Atvērt attēlu pilnekrānā">
						<Maximize2 aria-hidden="true" />
					</button>
					<span class="product-modal__image-count" data-product-modal-image-count></span>
					</div>
					<div class="product-modal__thumbs-shell">
						<button class="product-modal__thumb-nav" data-product-modal-thumbs-prev type="button" aria-label="Ritināt attēlus pa kreisi">
							<ChevronLeft aria-hidden="true" />
						</button>
						<div class="product-modal__thumbs" data-product-modal-thumbs aria-label="Produkta attēlu saraksts"></div>
						<button class="product-modal__thumb-nav" data-product-modal-thumbs-next type="button" aria-label="Ritināt attēlus pa labi">
							<ChevronRight aria-hidden="true" />
						</button>
					</div>
				</div>
				<div class="product-modal__content">
					<p class="product-modal__eyebrow" data-product-modal-category></p>
					<h2 id="product-modal-title" data-product-modal-title></h2>
					<div class="product-modal__tabs" role="tablist" aria-label="Produkta informācija">
						<button class="is-active" data-product-modal-tab="basic" role="tab" type="button" aria-selected="true">Pamata informācija</button>
						<button data-product-modal-tab="extra" role="tab" type="button" aria-selected="false">Papildus informācija</button>
					</div>
					<p class="product-modal__description" data-product-modal-description data-product-modal-basic></p>
					<dl class="product-modal__specs" data-product-modal-basic>
						<div>
							<RulerDimensionLine aria-hidden="true" />
							<dt>Izmērs</dt>
							<dd data-product-modal-size></dd>
						</div>
						<div>
							<UserRound aria-hidden="true" />
							<dt>Ietilpība</dt>
							<dd data-product-modal-capacity></dd>
						</div>
						<div>
							<Clock3 aria-hidden="true" />
							<dt>Uzstādīšana</dt>
							<dd data-product-modal-install></dd>
						</div>
						<div>
							<Euro aria-hidden="true" />
							<dt>Cena</dt>
							<dd data-product-modal-price></dd>
						</div>
					</dl>
					<div class="product-modal__dates" data-product-modal-basic aria-label="Nomas periods">
						<label>
							<span>No</span>
							<input data-product-modal-date-start type="date" />
						</label>
						<label>
							<span>Līdz</span>
							<input data-product-modal-date-end type="date" />
						</label>
					</div>
					<div class="product-modal__tab-panel" data-product-modal-panel="extra" role="tabpanel" hidden>
						<p class="product-modal__description" data-product-modal-additional></p>
					</div>
					<div class="product-modal__actions">
						<button class="product-modal__cta" data-product-modal-add type="button">
							<span>Pievienot grozam</span>
							<ShoppingBag aria-hidden="true" />
						</button>
						<div class="product-modal__quantity" aria-label="Daudzums">
							<button data-product-modal-quantity-decrease type="button" aria-label="Samazināt daudzumu">-</button>
							<span data-product-modal-quantity>1</span>
							<button data-product-modal-quantity-increase type="button" aria-label="Palielināt daudzumu">+</button>
						</div>
					</div>
				</div>
			</section>
			<div class="product-modal__fullscreen" data-product-modal-fullscreen hidden role="dialog" aria-modal="true" aria-label="Produkta attēls pilnekrānā">
				<button class="product-modal__fullscreen-backdrop" data-product-modal-fullscreen-close type="button" aria-label="Aizvērt pilnekrāna attēlu"></button>
				<div class="product-modal__fullscreen-stage">
					<img data-product-modal-fullscreen-image src="" alt="" />
					<button class="product-modal__fullscreen-close" data-product-modal-fullscreen-close type="button" aria-label="Aizvērt">
						<X aria-hidden="true" />
					</button>
					<button class="product-modal__fullscreen-nav product-modal__fullscreen-nav--prev" data-product-modal-fullscreen-prev type="button" aria-label="Iepriekšējais attēls">
						<ChevronLeft aria-hidden="true" />
					</button>
					<button class="product-modal__fullscreen-nav product-modal__fullscreen-nav--next" data-product-modal-fullscreen-next type="button" aria-label="Nākamais attēls">
						<ChevronRight aria-hidden="true" />
					</button>
				</div>
				<div class="product-modal__fullscreen-thumbs-shell">
					<button class="product-modal__thumb-nav" data-product-modal-fullscreen-thumbs-prev type="button" aria-label="Ritināt attēlus pa kreisi">
						<ChevronLeft aria-hidden="true" />
					</button>
					<div class="product-modal__thumbs" data-product-modal-fullscreen-thumbs aria-label="Pilnekrāna attēlu saraksts"></div>
					<button class="product-modal__thumb-nav" data-product-modal-fullscreen-thumbs-next type="button" aria-label="Ritināt attēlus pa labi">
						<ChevronRight aria-hidden="true" />
					</button>
				</div>
			</div>
		</div>
		<SiteFooter />
		<FloatingActions />
		<ScrollToTop />
	</div>
	<script id="product-modal-data" type="application/json" set:html={JSON.stringify(modalProducts)}></script>
</BaseLayout>

<style>
	.product-page {
		background:
			radial-gradient(circle at 78% 18%, rgba(203, 183, 154, 0.16), transparent 23rem),
			var(--color-background);
	}

	.product-category {
		width: min(100%, 1200px);
		margin: 0 auto;
		padding: clamp(1.6rem, 3vw, 2.5rem) clamp(1rem, 3vw, 1.5rem) 3.7rem;
	}

	.product-category__hero {
		padding: clamp(0.65rem, 1.5vw, 1.2rem) clamp(0.1rem, 1vw, 0.2rem) clamp(1.6rem, 3vw, 2.4rem);
	}

	.product-category__breadcrumbs {
		display: flex;
		align-items: center;
		gap: 0.42rem;
		color: var(--color-text-muted);
		font-size: 0.74rem;
		font-weight: 500;
	}

	.product-category__breadcrumbs a {
		color: var(--color-text-muted);
		text-decoration: none;
	}

	.product-category__breadcrumbs svg {
		width: 0.74rem;
		height: 0.74rem;
		stroke-width: 2;
	}

	.product-category__intro {
		margin-top: clamp(2.25rem, 4vw, 3.35rem);
		display: grid;
		grid-template-columns: minmax(0, 1fr) auto;
		align-items: end;
		gap: 1.5rem;
	}

	.product-category__intro h1 {
		margin: 0;
		color: var(--color-bark);
		font-size: clamp(3rem, 6vw, 5.1rem);
		font-weight: 500;
		letter-spacing: 0;
		line-height: 0.98;
	}

	.product-category__intro p {
		max-width: 29rem;
		margin: clamp(0.8rem, 1.5vw, 1rem) 0 0;
		color: var(--color-text-muted);
		font-size: clamp(0.95rem, 1.4vw, 1.05rem);
		font-weight: 500;
		line-height: 1.62;
	}

	.product-category__intro-actions {
		display: flex;
		align-items: center;
		justify-self: end;
		gap: 0.8rem;
	}

	.product-category__help {
		display: inline-flex;
		align-items: center;
		gap: 0.75rem;
		color: var(--color-bark);
		text-decoration: none;
	}

	.product-category__help > svg {
		width: 2rem;
		height: 2rem;
		color: var(--color-primary);
		stroke-width: 1.75;
	}

	.product-category__help span {
		display: grid;
		gap: 0.1rem;
		line-height: 1.15;
	}

	.product-category__help strong {
		color: var(--color-text-muted);
		font-size: 0.72rem;
		font-weight: 650;
	}

	.product-category__help span span {
		color: var(--color-bark);
		font-size: 0.74rem;
		font-weight: 700;
		text-decoration: underline;
		text-underline-offset: 0.16rem;
	}

	.product-category__controls {
		margin-bottom: clamp(1.7rem, 3vw, 2.35rem);
		padding: 1rem;
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
		background: rgba(255, 255, 255, 0.6);
		border: 1px solid rgba(222, 212, 198, 0.78);
		border-radius: 18px;
		box-shadow: var(--shadow-soft);
	}

	.product-category__tabs {
		display: flex;
		align-items: center;
		gap: 0.42rem;
		overflow-x: auto;
		scrollbar-width: none;
	}

	.product-category__tabs::-webkit-scrollbar {
		display: none;
	}

	.product-category__tab,
	.product-category__size-filter {
		min-height: 2.6rem;
		border: 1px solid transparent;
		border-radius: 0.7rem;
		cursor: pointer;
		font: inherit;
		font-size: 0.82rem;
		font-weight: 750;
		white-space: nowrap;
		transition:
			background-color 160ms ease,
			border-color 160ms ease,
			color 160ms ease,
			transform 160ms ease;
	}

	.product-category__tab {
		position: relative;
		padding: 0 1rem;
		color: var(--color-bark);
		background: transparent;
	}

	.product-category__tab::after {
		position: absolute;
		right: 0.75rem;
		bottom: -0.52rem;
		left: 0.75rem;
		height: 2px;
		background: #6b7a4a;
		border-radius: 999px;
		content: "";
		opacity: 0;
		transform: scaleX(0.5);
		transition:
			opacity 160ms ease,
			transform 160ms ease;
	}

	.product-category__tab.is-active,
	.product-category__tab:hover {
		color: var(--color-surface);
		background: #6b7a4a;
	}

	.product-category__tab.is-active::after {
		opacity: 1;
		transform: scaleX(1);
	}

	.product-category__size-filter {
		position: relative;
		padding: 0 0.6rem 0 0.8rem;
		display: inline-flex;
		align-items: center;
		gap: 0.45rem;
		color: var(--color-bark);
		background: rgba(255, 255, 255, 0.64);
		border-color: rgba(222, 212, 198, 0.96);
	}

	.product-category__size-filter:hover {
		background: var(--color-background-soft);
	}

	.product-category__size-filter svg {
		flex: 0 0 auto;
		width: 1rem;
		height: 1rem;
		stroke-width: 2;
	}

	.product-category__size-filter select {
		min-width: 7.5rem;
		padding: 0 1.25rem 0 0;
		color: inherit;
		background: transparent;
		border: 0;
		cursor: pointer;
		font: inherit;
		font-size: inherit;
		font-weight: inherit;
		outline: none;
		appearance: none;
	}

	.product-category__size-filter select:focus-visible {
		outline: 2px solid rgba(107, 122, 74, 0.35);
		outline-offset: 4px;
		border-radius: 0.45rem;
	}

	.product-category__size-filter svg:last-child {
		position: absolute;
		right: 0.62rem;
		pointer-events: none;
	}

	.product-category__size-filter--mobile {
		display: none;
	}

	.product-category__grid {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: clamp(1.1rem, 2.3vw, 1.55rem);
	}

	.product-card {
		min-width: 0;
		overflow: hidden;
		background: rgba(255, 255, 255, 0.7);
		border: 1px solid rgba(222, 212, 198, 0.82);
		border-radius: 12px;
		box-shadow: 0 13px 26px rgba(75, 64, 56, 0.08);
		cursor: pointer;
		transition:
			border-color 180ms ease,
			box-shadow 180ms ease,
			transform 180ms ease;
	}

	.product-card:hover {
		border-color: rgba(138, 146, 113, 0.38);
		box-shadow: 0 18px 38px rgba(75, 64, 56, 0.13);
		transform: translateY(-4px);
	}

	.product-card:focus-visible {
		outline: 2px solid var(--color-primary);
		outline-offset: 4px;
		box-shadow: var(--focus-ring), 0 18px 38px rgba(75, 64, 56, 0.13);
	}

	.product-card[hidden] {
		display: none;
	}

	.product-card__media {
		position: relative;
		display: block;
		aspect-ratio: 1.42 / 1;
		overflow: hidden;
		color: var(--color-surface);
		text-decoration: none;
	}

	.product-card__media img {
		width: 100%;
		height: 100%;
		display: block;
		object-fit: cover;
		transition: transform 220ms ease;
	}

	.product-card:hover .product-card__media img {
		transform: scale(1.035);
	}

	.product-card__badge {
		position: absolute;
		top: 0.72rem;
		left: 0.72rem;
		z-index: 1;
		padding: 0.34rem 0.55rem;
		background: rgba(107, 122, 74, 0.94);
		border-radius: 999px;
		color: var(--color-surface);
		font-size: 0.68rem;
		font-weight: 760;
	}

	.product-card__body {
		padding: 1.05rem 1rem 1rem;
	}

	.product-card__body h2 {
		margin: 0;
		color: var(--color-bark);
		font-size: clamp(1.02rem, 1.5vw, 1.2rem);
		font-weight: 650;
		letter-spacing: 0;
		line-height: 1.24;
	}

	.product-card__meta {
		margin-top: 0.65rem;
		display: flex;
		gap: 0.55rem;
		flex-wrap: wrap;
		color: var(--color-text-muted);
		font-size: 0.78rem;
		font-weight: 600;
	}

	.product-card__meta span {
		padding: 0.28rem 0.45rem;
		background: rgba(237, 228, 215, 0.66);
		border-radius: 999px;
	}

	.product-card ul {
		margin: 0.88rem 0 1rem;
		padding: 0;
		display: grid;
		gap: 0.48rem;
		list-style: none;
		color: var(--color-bark);
		font-size: 0.82rem;
		font-weight: 550;
	}

	.product-card li {
		display: flex;
		align-items: center;
		gap: 0.42rem;
	}

	.product-card li svg {
		width: 0.95rem;
		height: 0.95rem;
		color: #6b7a4a;
		stroke-width: 2;
	}

	.product-card__button {
		min-height: 2.55rem;
		padding: 0 1rem;
		display: flex;
		align-items: center;
		justify-content: center;
		gap: 0.65rem;
		color: var(--color-surface);
		background: #6b7a4a;
		border: 0;
		border-radius: 999px;
		font-size: 0.78rem;
		font-family: inherit;
		font-weight: 820;
