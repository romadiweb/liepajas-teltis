---
import ArrowRight from '@lucide/astro/icons/arrow-right';
import ChevronDown from '@lucide/astro/icons/chevron-down';
import ChevronRight from '@lucide/astro/icons/chevron-right';
import Clock3 from '@lucide/astro/icons/clock-3';
import MessageCircleQuestionMark from '@lucide/astro/icons/message-circle-question-mark';
import Ruler from '@lucide/astro/icons/ruler';
import RulerDimensionLine from '@lucide/astro/icons/ruler-dimension-line';
import Users from '@lucide/astro/icons/users';
import X from '@lucide/astro/icons/x';
import BaseLayout from './BaseLayout.astro';
import FloatingActions from '../components/common/FloatingActions.astro';
import ScrollToTop from '../components/common/ScrollToTop.astro';
import SiteFooter from '../components/common/SiteFooter.astro';
import SiteHeader from '../components/common/SiteHeader.astro';

type FilterItem = {
	active?: boolean;
	label: string;
};

type ProductItem = {
	badge?: string;
	capacity: string;
	category: string;
	description?: string;
	href?: string;
	image: string;
	installTime: string;
	size: string;
	title: string;
};

interface Props {
	breadcrumbCurrent: string;
	description: string;
	filters: FilterItem[];
	products: ProductItem[];
	title: string;
}

const { breadcrumbCurrent, description, filters, products, title } = Astro.props;
const allFilterLabel = filters[0]?.label;
const modalProducts = products.map((product) => ({
	capacity: product.capacity,
	category: product.category,
	description:
		product.description ??
		`${product.title} ir piemērota izvēle pasākumiem, kur nepieciešams pārdomāts izmērs, stabila konstrukcija un sakopts vizuālais iespaids. Pielāgosim komplektāciju jūsu viesu skaitam, norises vietai un vēlamajam inventāram.`,
	href: product.href ?? '#kontakti',
	image: product.image,
	installTime: product.installTime,
	size: product.size,
	title: product.title,
}));
---

<BaseLayout title={`${title} | Liepājas teltis`} description={description}>
	<div class="page-shell product-page">
		<SiteHeader />
		<main class="product-category" aria-labelledby="product-category-title">
			<section class="product-category__hero">
				<nav class="product-category__breadcrumbs" aria-label="Lapas ceļš">
					<a href="/">Sākums</a>
					<ChevronRight aria-hidden="true" />
					<span>{breadcrumbCurrent}</span>
				</nav>

				<div class="product-category__intro">
					<div>
						<h1 id="product-category-title">{title}</h1>
						<p>{description}</p>
					</div>
					<a class="product-category__help" href="#kontakti">
						<MessageCircleQuestionMark aria-hidden="true" />
						<span>
							<strong>Nepieciešama palīdzība?</strong>
							<span>Sazinies ar mums</span>
						</span>
					</a>
				</div>
			</section>

			<section class="product-category__controls" aria-label="Produktu filtri">
				<div class="product-category__tabs">
					{
						filters.map((filter) => (
							<button
								aria-pressed={filter.active ? 'true' : 'false'}
								class:list={['product-category__tab', { 'is-active': filter.active }]}
								data-product-filter={filter.label === allFilterLabel ? 'all' : filter.label}
								type="button"
							>
								{filter.label}
							</button>
						))
					}
				</div>
				<button class="product-category__select" type="button">
					<Ruler aria-hidden="true" />
					<span>Izmērs</span>
					<ChevronDown aria-hidden="true" />
				</button>
			</section>

			<section class="product-category__grid" aria-label={`${title} piedāvājums`}>
				{
					products.map((product, index) => (
						<article
							aria-label={`Atvērt informāciju: ${product.title}`}
							class="product-card"
							data-product-category={product.category}
							data-product-open={index}
							role="button"
							tabindex="0"
						>
							<div class="product-card__media">
								{product.badge && <span class="product-card__badge">{product.badge}</span>}
								<img src={product.image} alt={product.title} loading="lazy" />
							</div>
							<div class="product-card__body">
								<h2>{product.title}</h2>
								<div class="product-card__meta">
									<span>{product.category}</span>
									<span>{product.size}</span>
								</div>
								<ul>
									<li>
										<Users aria-hidden="true" />
										<span>{product.capacity}</span>
									</li>
									<li>
										<Clock3 aria-hidden="true" />
										<span>{product.installTime}</span>
									</li>
								</ul>
								<span class="product-card__button">
									<span>Skatīt vairāk</span>
									<ArrowRight aria-hidden="true" />
								</span>
							</div>
						</article>
					))
				}
			</section>

			<section class="product-category__cta" aria-label="Pieteikt citu telts izmēru">
				<div class="product-category__cta-icon">
					<RulerDimensionLine aria-hidden="true" />
				</div>
				<div>
					<h2>Neatradi piemērotu izmēru?</h2>
					<p>Piedāvājam teltis dažādos izmēros un konfigurācijās. Sazinies ar mums - palīdzēsim atrast labāko risinājumu.</p>
				</div>
				<a href="#kontakti">
					<span>Sazināties</span>
					<ArrowRight aria-hidden="true" />
				</a>
			</section>
		</main>
		<div class="product-modal" data-product-modal hidden role="dialog" aria-modal="true" aria-labelledby="product-modal-title">
			<button class="product-modal__backdrop" data-product-modal-close type="button" aria-label="Aizvērt produkta aprakstu"></button>
			<section class="product-modal__window" tabindex="-1">
				<button class="product-modal__close" data-product-modal-close type="button" aria-label="Aizvērt">
					<X aria-hidden="true" />
				</button>
				<div class="product-modal__media">
					<img data-product-modal-image src="" alt="" />
				</div>
				<div class="product-modal__content">
					<p class="product-modal__eyebrow" data-product-modal-category></p>
					<h2 id="product-modal-title" data-product-modal-title></h2>
					<p class="product-modal__description" data-product-modal-description></p>
					<dl class="product-modal__specs">
						<div>
							<dt>Izmērs</dt>
							<dd data-product-modal-size></dd>
						</div>
						<div>
							<dt>Ietilpība</dt>
							<dd data-product-modal-capacity></dd>
						</div>
						<div>
							<dt>Uzstādīšana</dt>
							<dd data-product-modal-install></dd>
						</div>
					</dl>
					<a class="product-modal__cta" data-product-modal-cta href="#kontakti">
						<span>Pieteikt nomu</span>
						<ArrowRight aria-hidden="true" />
					</a>
				</div>
			</section>
		</div>
		<SiteFooter />
		<FloatingActions />
		<ScrollToTop />
	</div>
	<script id="product-modal-data" type="application/json" set:html={JSON.stringify(modalProducts)}></script>
</BaseLayout>

<style>
	.product-page {
		background:
			radial-gradient(circle at 78% 18%, rgba(203, 183, 154, 0.16), transparent 23rem),
			var(--color-background);
	}

	.product-category {
		width: min(100%, 1200px);
		margin: 0 auto;
		padding: clamp(1.6rem, 3vw, 2.5rem) clamp(1rem, 3vw, 1.5rem) 3.7rem;
	}

	.product-category__hero {
		padding: clamp(0.65rem, 1.5vw, 1.2rem) clamp(0.1rem, 1vw, 0.2rem) clamp(1.6rem, 3vw, 2.4rem);
	}

	.product-category__breadcrumbs {
		display: flex;
		align-items: center;
		gap: 0.42rem;
		color: var(--color-text-muted);
		font-size: 0.74rem;
		font-weight: 500;
	}

	.product-category__breadcrumbs a {
		color: var(--color-text-muted);
		text-decoration: none;
	}

	.product-category__breadcrumbs svg {
		width: 0.74rem;
		height: 0.74rem;
		stroke-width: 2;
	}

	.product-category__intro {
		margin-top: clamp(2.25rem, 4vw, 3.35rem);
		display: grid;
		grid-template-columns: minmax(0, 1fr) auto;
		align-items: end;
		gap: 1.5rem;
	}

	.product-category__intro h1 {
		margin: 0;
		color: var(--color-bark);
		font-size: clamp(3rem, 6vw, 5.1rem);
		font-weight: 500;
		letter-spacing: 0;
		line-height: 0.98;
	}

	.product-category__intro p {
		max-width: 29rem;
		margin: clamp(0.8rem, 1.5vw, 1rem) 0 0;
		color: var(--color-text-muted);
		font-size: clamp(0.95rem, 1.4vw, 1.05rem);
		font-weight: 500;
		line-height: 1.62;
	}

	.product-category__help {
		display: inline-flex;
		align-items: center;
		gap: 0.75rem;
		color: var(--color-bark);
		text-decoration: none;
	}

	.product-category__help > svg {
		width: 2rem;
		height: 2rem;
		color: var(--color-primary);
		stroke-width: 1.75;
	}

	.product-category__help span {
		display: grid;
		gap: 0.1rem;
		line-height: 1.15;
	}

	.product-category__help strong {
		color: var(--color-text-muted);
		font-size: 0.72rem;
		font-weight: 650;
	}

	.product-category__help span span {
		color: var(--color-bark);
		font-size: 0.74rem;
		font-weight: 700;
		text-decoration: underline;
		text-underline-offset: 0.16rem;
	}

	.product-category__controls {
		margin-bottom: clamp(1.7rem, 3vw, 2.35rem);
		padding: 1rem;
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
		background: rgba(255, 255, 255, 0.6);
		border: 1px solid rgba(222, 212, 198, 0.78);
		border-radius: 18px;
		box-shadow: var(--shadow-soft);
	}

	.product-category__tabs {
		display: flex;
		align-items: center;
		gap: 0.42rem;
		overflow-x: auto;
		scrollbar-width: none;
	}

	.product-category__tabs::-webkit-scrollbar {
		display: none;
	}

	.product-category__tab,
	.product-category__select {
		min-height: 2.6rem;
		border: 1px solid transparent;
		border-radius: 0.7rem;
		cursor: pointer;
		font: inherit;
		font-size: 0.82rem;
		font-weight: 750;
		white-space: nowrap;
		transition:
			background-color 160ms ease,
			border-color 160ms ease,
			color 160ms ease,
			transform 160ms ease;
	}

	.product-category__tab {
		position: relative;
		padding: 0 1rem;
		color: var(--color-bark);
		background: transparent;
	}

	.product-category__tab::after {
		position: absolute;
		right: 0.75rem;
		bottom: -0.52rem;
		left: 0.75rem;
		height: 2px;
		background: #6b7a4a;
		border-radius: 999px;
		content: "";
		opacity: 0;
		transform: scaleX(0.5);
		transition:
			opacity 160ms ease,
			transform 160ms ease;
	}

	.product-category__tab.is-active,
	.product-category__tab:hover {
		color: var(--color-surface);
		background: #6b7a4a;
	}

	.product-category__tab.is-active::after {
		opacity: 1;
		transform: scaleX(1);
	}

	.product-category__select {
		padding: 0 0.8rem;
		display: inline-flex;
		align-items: center;
		gap: 0.45rem;
		color: var(--color-bark);
		background: rgba(255, 255, 255, 0.64);
		border-color: rgba(222, 212, 198, 0.96);
	}

	.product-category__select:hover {
		background: var(--color-background-soft);
	}

	.product-category__select svg {
		width: 1rem;
		height: 1rem;
		stroke-width: 2;
	}

	.product-category__grid {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: clamp(1.1rem, 2.3vw, 1.55rem);
	}

	.product-card {
		min-width: 0;
		overflow: hidden;
		background: rgba(255, 255, 255, 0.7);
		border: 1px solid rgba(222, 212, 198, 0.82);
		border-radius: 12px;
		box-shadow: 0 13px 26px rgba(75, 64, 56, 0.08);
		cursor: pointer;
		transition:
			border-color 180ms ease,
			box-shadow 180ms ease,
			transform 180ms ease;
	}

	.product-card:hover {
		border-color: rgba(138, 146, 113, 0.38);
		box-shadow: 0 18px 38px rgba(75, 64, 56, 0.13);
		transform: translateY(-4px);
	}

	.product-card:focus-visible {
		outline: 2px solid var(--color-primary);
		outline-offset: 4px;
		box-shadow: var(--focus-ring), 0 18px 38px rgba(75, 64, 56, 0.13);
	}

	.product-card[hidden] {
		display: none;
	}

	.product-card__media {
		position: relative;
		display: block;
		aspect-ratio: 1.42 / 1;
		overflow: hidden;
		color: var(--color-surface);
		text-decoration: none;
	}

	.product-card__media img {
		width: 100%;
		height: 100%;
		display: block;
		object-fit: cover;
		transition: transform 220ms ease;
	}

	.product-card:hover .product-card__media img {
		transform: scale(1.035);
	}

	.product-card__badge {
		position: absolute;
		top: 0.72rem;
		left: 0.72rem;
		z-index: 1;
		padding: 0.34rem 0.55rem;
		background: rgba(107, 122, 74, 0.94);
		border-radius: 999px;
		color: var(--color-surface);
		font-size: 0.68rem;
		font-weight: 760;
	}

	.product-card__body {
		padding: 1.05rem 1rem 1rem;
	}

	.product-card__body h2 {
		margin: 0;
		color: var(--color-bark);
		font-size: clamp(1.02rem, 1.5vw, 1.2rem);
		font-weight: 650;
		letter-spacing: 0;
		line-height: 1.24;
	}

	.product-card__meta {
		margin-top: 0.65rem;
		display: flex;
		gap: 0.55rem;
		flex-wrap: wrap;
		color: var(--color-text-muted);
		font-size: 0.78rem;
		font-weight: 600;
	}

	.product-card__meta span {
		padding: 0.28rem 0.45rem;
		background: rgba(237, 228, 215, 0.66);
		border-radius: 999px;
	}

	.product-card ul {
		margin: 0.88rem 0 1rem;
		padding: 0;
		display: grid;
		gap: 0.48rem;
		list-style: none;
		color: var(--color-bark);
		font-size: 0.82rem;
		font-weight: 550;
	}

	.product-card li {
		display: flex;
		align-items: center;
		gap: 0.42rem;
	}

	.product-card li svg {
		width: 0.95rem;
		height: 0.95rem;
		color: #6b7a4a;
		stroke-width: 2;
	}

	.product-card__button {
		min-height: 2.55rem;
		padding: 0 1rem;
		display: flex;
		align-items: center;
		justify-content: center;
		gap: 0.65rem;
		color: var(--color-surface);
		background: #6b7a4a;
		border: 0;
		border-radius: 999px;
		font-size: 0.78rem;
		font-family: inherit;
		font-weight: 820;
		text-decoration: none;
	}

	.product-card__button:hover {
		color: var(--color-surface);
		background: var(--color-primary-hover);
		transform: translateY(-1px);
	}

	.product-card__button svg {
		width: 0.92rem;
		height: 0.92rem;
		stroke-width: 2.25;
	}

	.product-category__cta {
		margin-top: clamp(1.7rem, 3vw, 2.4rem);
		padding: clamp(1rem, 2vw, 1.4rem) clamp(1.1rem, 2.6vw, 2rem);
		display: grid;
		grid-template-columns: auto minmax(0, 1fr) auto;
		align-items: center;
		gap: 1.1rem;
		background: rgba(255, 255, 255, 0.62);
		border: 1px solid rgba(222, 212, 198, 0.86);
		border-radius: 16px;
		box-shadow: var(--shadow-soft);
	}

	.product-category__cta-icon {
		width: 3.1rem;
		height: 3.1rem;
		display: grid;
		place-items: center;
		color: #6b7a4a;
		border: 1px solid rgba(138, 146, 113, 0.28);
		border-radius: 0.8rem;
	}

	.product-category__cta-icon svg {
		width: 1.55rem;
		height: 1.55rem;
		stroke-width: 1.9;
	}

	.product-category__cta h2 {
		margin: 0;
		color: var(--color-bark);
		font-size: 1.05rem;
		font-weight: 740;
		letter-spacing: 0;
	}

	.product-category__cta p {
		max-width: 42rem;
		margin: 0.28rem 0 0;
		color: var(--color-text-muted);
		font-size: 0.86rem;
		font-weight: 500;
		line-height: 1.45;
	}

	.product-category__cta a {
		min-height: 2.8rem;
		padding: 0 1.35rem;
		display: inline-flex;
		align-items: center;
		justify-content: center;
		gap: 0.65rem;
		color: var(--color-surface);
		background: #6b7a4a;
		border-radius: 999px;
		font-size: 0.78rem;
		font-weight: 820;
		text-decoration: none;
		white-space: nowrap;
	}

	.product-category__cta a:hover {
		color: var(--color-surface);
		background: var(--color-primary-hover);
		transform: translateY(-1px);
	}

	.product-category__cta a svg {
		width: 0.92rem;
		height: 0.92rem;
		stroke-width: 2.25;
	}

	:global(body.product-modal-open) {
		overflow: hidden;
	}

	.product-modal[hidden] {
		display: none;
	}

	.product-modal {
		position: fixed;
		inset: 0;
		z-index: 120;
		padding: clamp(1rem, 3vw, 2rem);
		display: grid;
		place-items: center;
	}

	.product-modal__backdrop {
		position: absolute;
		inset: 0;
		background: rgba(75, 64, 56, 0.26);
		border: 0;
		-webkit-backdrop-filter: blur(10px);
		backdrop-filter: blur(10px);
		cursor: pointer;
	}

	.product-modal__window {
		position: relative;
		z-index: 1;
		width: min(100%, 980px);
		max-height: min(84vh, 720px);
		display: grid;
		grid-template-columns: minmax(19rem, 0.92fr) minmax(0, 1fr);
		overflow: hidden;
		background:
			radial-gradient(circle at 100% 0%, rgba(203, 183, 154, 0.18), transparent 18rem),
			rgba(255, 255, 255, 0.92);
		border: 1px solid rgba(222, 212, 198, 0.92);
		border-radius: 24px;
		box-shadow: 0 30px 80px rgba(75, 64, 56, 0.26);
		opacity: 0;
		transform: translateY(1rem) scale(0.98);
		transition:
			opacity 180ms ease,
			transform 180ms ease;
	}

	.product-modal.is-open .product-modal__window {
		opacity: 1;
		transform: translateY(0) scale(1);
	}

	.product-modal__close {
		position: absolute;
		top: 1rem;
		right: 1rem;
		z-index: 2;
		width: 2.55rem;
		height: 2.55rem;
		display: grid;
		place-items: center;
		color: var(--color-bark);
		background: rgba(246, 241, 231, 0.9);
		border: 1px solid rgba(222, 212, 198, 0.96);
		border-radius: 999px;
		cursor: pointer;
	}

	.product-modal__close:hover {
		background: var(--color-background-soft);
		transform: translateY(-1px);
	}

	.product-modal__close svg {
		width: 1.12rem;
		height: 1.12rem;
		stroke-width: 2.25;
	}

	.product-modal__media {
		min-height: 26rem;
		background: var(--color-background-soft);
	}

	.product-modal__media img {
		width: 100%;
		height: 100%;
		display: block;
		object-fit: cover;
	}

	.product-modal__content {
		min-width: 0;
		padding: clamp(1.5rem, 3vw, 2.45rem);
		overflow-y: auto;
		color: var(--color-bark);
	}

	.product-modal__eyebrow {
		margin: 0 3rem 0.6rem 0;
		color: var(--color-primary);
		font-size: 0.72rem;
		font-weight: 820;
		letter-spacing: 0.16em;
		line-height: 1.25;
		text-transform: uppercase;
	}

	.product-modal__content h2 {
		max-width: 8.7em;
		margin: 0;
		color: var(--color-bark);
		font-size: clamp(2rem, 3.8vw, 3.4rem);
		font-weight: 500;
		letter-spacing: 0;
		line-height: 1.02;
	}

	.product-modal__description {
		max-width: 34rem;
		margin: clamp(1rem, 2vw, 1.35rem) 0 0;
		color: var(--color-text-muted);
		font-size: 0.98rem;
		font-weight: 500;
		line-height: 1.7;
	}

	.product-modal__specs {
		margin: clamp(1.25rem, 2vw, 1.65rem) 0 0;
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 0.75rem;
	}

	.product-modal__specs div {
		min-width: 0;
		padding: 0.85rem;
		background: rgba(237, 228, 215, 0.58);
		border: 1px solid rgba(222, 212, 198, 0.78);
		border-radius: 12px;
	}

	.product-modal__specs dt {
		margin: 0 0 0.28rem;
		color: var(--color-text-muted);
		font-size: 0.66rem;
		font-weight: 780;
		letter-spacing: 0.12em;
