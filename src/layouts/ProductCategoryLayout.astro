			width: 100%;
		}

		.product-category__cta {
			grid-template-columns: 1fr;
			gap: 0.85rem;
		}

		.product-category__cta a {
			width: 100%;
		}
	}
</style>

<script>
	type ProductModalItem = {
		capacity: string;
		category: string;
		description: string;
		href: string;
		image: string;
		installTime: string;
		size: string;
		title: string;
	};

	const productFilterButtons = document.querySelectorAll<HTMLButtonElement>('[data-product-filter]');
	const productCards = document.querySelectorAll<HTMLElement>('[data-product-category]');
	const productModalData = document.querySelector<HTMLScriptElement>('#product-modal-data');
	const productModal = document.querySelector<HTMLElement>('[data-product-modal]');
	const productModalWindow = document.querySelector<HTMLElement>('.product-modal__window');
	const productModalCloseButtons = document.querySelectorAll<HTMLButtonElement>('[data-product-modal-close]');
	const productModalImage = document.querySelector<HTMLImageElement>('[data-product-modal-image]');
	const productModalCategory = document.querySelector<HTMLElement>('[data-product-modal-category]');
	const productModalTitle = document.querySelector<HTMLElement>('[data-product-modal-title]');
	const productModalDescription = document.querySelector<HTMLElement>('[data-product-modal-description]');
	const productModalSize = document.querySelector<HTMLElement>('[data-product-modal-size]');
	const productModalCapacity = document.querySelector<HTMLElement>('[data-product-modal-capacity]');
	const productModalInstall = document.querySelector<HTMLElement>('[data-product-modal-install]');
	const productModalCta = document.querySelector<HTMLAnchorElement>('[data-product-modal-cta]');
	const modalProducts: ProductModalItem[] = productModalData?.textContent ? JSON.parse(productModalData.textContent) : [];
	let lastFocusedProductElement: HTMLElement | null = null;

	productFilterButtons.forEach((button) => {
		button.addEventListener('click', () => {
			const activeFilter = button.dataset.productFilter ?? 'all';

			productFilterButtons.forEach((filterButton) => {
				const isActive = filterButton === button;
				filterButton.classList.toggle('is-active', isActive);
				filterButton.setAttribute('aria-pressed', String(isActive));
			});

			productCards.forEach((card) => {
				card.hidden = activeFilter !== 'all' && card.dataset.productCategory !== activeFilter;
			});
		});
	});

	const setText = (element: HTMLElement | null, text: string) => {
		if (element) {
			element.textContent = text;
		}
	};

	const closeProductModal = () => {
		if (!productModal || productModal.hidden) {
			return;
		}

		productModal.classList.remove('is-open');
		document.body.classList.remove('product-modal-open');
		window.setTimeout(() => {
			productModal.hidden = true;
			lastFocusedProductElement?.focus();
			lastFocusedProductElement = null;
		}, 180);
	};

	const openProductModal = (productIndex: number, trigger: HTMLElement) => {
		const product = modalProducts[productIndex];

		if (!product || !productModal) {
			return;
		}

		lastFocusedProductElement = trigger;
		setText(productModalCategory, product.category);
		setText(productModalTitle, product.title);
		setText(productModalDescription, product.description);
		setText(productModalSize, product.size);
		setText(productModalCapacity, product.capacity);
		setText(productModalInstall, product.installTime.replace(/^Uzstādīšanas laiks:\s*/i, ''));

		if (productModalImage) {
			productModalImage.src = product.image;
			productModalImage.alt = product.title;
		}

		if (productModalCta) {
			productModalCta.href = product.href;
		}

		productModal.hidden = false;
		document.body.classList.add('product-modal-open');
		window.requestAnimationFrame(() => {
			productModal.classList.add('is-open');
			productModalWindow?.focus();
		});
	};

	productCards.forEach((card) => {
		card.addEventListener('click', () => {
			openProductModal(Number(card.dataset.productOpen), card);
		});

		card.addEventListener('keydown', (event) => {
			if (event.key === 'Enter' || event.key === ' ') {
				event.preventDefault();
				openProductModal(Number(card.dataset.productOpen), card);
			}
		});
	});

	productModalCloseButtons.forEach((button) => {
		button.addEventListener('click', closeProductModal);
	});

	productModalCta?.addEventListener('click', () => {
		closeProductModal();
	});

	document.addEventListener('keydown', (event) => {
		if (event.key === 'Escape') {
			closeProductModal();
		}
	});
</script>
