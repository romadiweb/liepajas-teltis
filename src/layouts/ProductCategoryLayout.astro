		}

		.product-card {
			border-radius: 10px;
		}

		.product-card__media {
			aspect-ratio: 1.18 / 1;
		}

		.product-card__body {
			padding: 0.82rem 0.72rem 0.78rem;
		}

		.product-card__body h2 {
			font-size: 0.88rem;
		}

		.product-card__meta {
			gap: 0.35rem;
			font-size: 0.64rem;
		}

		.product-card ul {
			font-size: 0.68rem;
		}

		.product-card__button {
			min-height: 2.35rem;
			font-size: 0.68rem;
		}

		.product-modal {
			padding: 0.7rem;
		}

		.product-modal__window {
			border-radius: 18px;
		}

		.product-modal__close {
			top: 0.72rem;
			right: 0.72rem;
			width: 2.35rem;
			height: 2.35rem;
		}

		.product-modal__media {
			min-height: 12.5rem;
			padding: 0.55rem;
		}

		.product-modal__content {
			display: flex;
			flex-direction: column;
			padding: 1.15rem;
		}

		.product-modal__fullscreen-button {
			top: auto;
			right: auto;
			bottom: 0.82rem;
			left: 0.82rem;
			width: 2.25rem;
			height: 2.25rem;
		}

		.product-modal__content h2 {
			order: 1;
			max-width: none;
			font-size: clamp(1.45rem, 8vw, 2rem);
			line-height: 1.05;
		}

		.product-modal__tabs {
			order: 3;
			margin-top: 0.85rem;
			gap: 0.75rem;
			overflow-x: auto;
			scrollbar-width: none;
		}

		.product-modal__tabs::-webkit-scrollbar {
			display: none;
		}

		.product-modal__tabs button {
			flex: 0 0 auto;
			font-size: 0.68rem;
		}

		.product-modal__eyebrow {
			order: 0;
			margin-bottom: 0.35rem;
			font-size: 0.62rem;
		}

		.product-modal__description {
			order: 4;
			margin-top: 0.75rem;
			font-size: 0.9rem;
			line-height: 1.58;
		}

		.product-modal__specs {
			order: 4;
			grid-template-columns: repeat(2, minmax(0, 1fr));
			gap: 0.45rem;
			margin-top: 0.75rem;
		}

		.product-modal__specs div {
			grid-template-columns: auto minmax(0, 1fr);
			column-gap: 0.42rem;
			padding: 0.58rem;
			border-radius: 10px;
		}

		.product-modal__specs svg {
			width: 0.86rem;
			height: 0.86rem;
			margin-top: 0.05rem;
		}

		.product-modal__specs dt {
			margin-bottom: 0.16rem;
			font-size: 0.54rem;
			letter-spacing: 0.09em;
		}

		.product-modal__specs dd {
			font-size: 0.76rem;
			line-height: 1.22;
		}

		.product-modal__dates {
			order: 4;
			grid-template-columns: 1fr;
			gap: 0.5rem;
			margin-top: 0.7rem;
		}

		.product-modal__dates span {
			font-size: 0.58rem;
		}

		.product-modal__dates input {
			min-height: 2.35rem;
			font-size: 0.78rem;
		}

		.product-modal__tab-panel {
			order: 4;
			min-height: 10rem;
		}

		:global(.product-modal__thumb) {
			width: 3.8rem;
			height: 3.8rem;
			border-radius: 11px;
		}

		:global(.product-modal__thumb img) {
			border-radius: 8px;
		}

		.product-modal__actions {
			order: 2;
			width: 100%;
			grid-template-columns: minmax(0, 1fr) auto;
			gap: 0.55rem;
			margin-top: 0.85rem;
		}

		.product-modal__cta {
			min-height: 2.55rem;
			padding-inline: 0.9rem;
			font-size: 0.72rem;
		}

		.product-modal__quantity {
			min-height: 2.55rem;
			grid-template-columns: 1.95rem 1.7rem 1.95rem;
			font-size: 0.78rem;
		}

		.product-category__cta {
			grid-template-columns: 1fr;
			gap: 0.85rem;
		}

		.product-category__cta a {
			width: 100%;
		}
	}
</style>

<script>
	type ProductModalItem = {
		additionalInfo: string;
		capacity: string;
		category: string;
		description: string;
		galleryImages: string[];
		href: string;
		id: string;
		image: string;
		installTime: string;
		priceCents: number;
		size: string;
		title: string;
		variant: string;
	};

	const productFilterButtons = document.querySelectorAll<HTMLButtonElement>('[data-product-filter]');
	const productSizeFilters = document.querySelectorAll<HTMLSelectElement>('[data-product-size-filter]');
	const productCards = document.querySelectorAll<HTMLElement>('[data-product-category]');
	const productModalData = document.querySelector<HTMLScriptElement>('#product-modal-data');
	const productModal = document.querySelector<HTMLElement>('[data-product-modal]');
	const productModalWindow = document.querySelector<HTMLElement>('.product-modal__window');
	const productModalCloseButtons = document.querySelectorAll<HTMLButtonElement>('[data-product-modal-close]');
	const productModalImage = document.querySelector<HTMLImageElement>('[data-product-modal-image]');
	const productModalImageCount = document.querySelector<HTMLElement>('[data-product-modal-image-count]');
	const productModalPrev = document.querySelector<HTMLButtonElement>('[data-product-modal-prev]');
	const productModalNext = document.querySelector<HTMLButtonElement>('[data-product-modal-next]');
	const productModalThumbs = document.querySelector<HTMLElement>('[data-product-modal-thumbs]');
	const productModalThumbsPrev = document.querySelector<HTMLButtonElement>('[data-product-modal-thumbs-prev]');
	const productModalThumbsNext = document.querySelector<HTMLButtonElement>('[data-product-modal-thumbs-next]');
	const productModalFullscreenOpen = document.querySelector<HTMLButtonElement>('[data-product-modal-fullscreen-open]');
	const productModalFullscreen = document.querySelector<HTMLElement>('[data-product-modal-fullscreen]');
	const productModalImageStage = document.querySelector<HTMLElement>('[data-product-modal-image-stage]');
	const productModalFullscreenStage = document.querySelector<HTMLElement>('.product-modal__fullscreen-stage');
	const productModalFullscreenImage = document.querySelector<HTMLImageElement>('[data-product-modal-fullscreen-image]');
	const productModalFullscreenCloseButtons = document.querySelectorAll<HTMLButtonElement>('[data-product-modal-fullscreen-close]');
	const productModalFullscreenPrev = document.querySelector<HTMLButtonElement>('[data-product-modal-fullscreen-prev]');
	const productModalFullscreenNext = document.querySelector<HTMLButtonElement>('[data-product-modal-fullscreen-next]');
	const productModalFullscreenThumbs = document.querySelector<HTMLElement>('[data-product-modal-fullscreen-thumbs]');
	const productModalFullscreenThumbsPrev = document.querySelector<HTMLButtonElement>('[data-product-modal-fullscreen-thumbs-prev]');
	const productModalFullscreenThumbsNext = document.querySelector<HTMLButtonElement>('[data-product-modal-fullscreen-thumbs-next]');
	const productModalCategory = document.querySelector<HTMLElement>('[data-product-modal-category]');
	const productModalTitle = document.querySelector<HTMLElement>('[data-product-modal-title]');
	const productModalDescription = document.querySelector<HTMLElement>('[data-product-modal-description]');
	const productModalAdditional = document.querySelector<HTMLElement>('[data-product-modal-additional]');
	const productModalTabs = document.querySelectorAll<HTMLButtonElement>('[data-product-modal-tab]');
	const productModalBasicNodes = document.querySelectorAll<HTMLElement>('[data-product-modal-basic]');
	const productModalExtraPanel = document.querySelector<HTMLElement>('[data-product-modal-panel="extra"]');
	const productModalSize = document.querySelector<HTMLElement>('[data-product-modal-size]');
	const productModalCapacity = document.querySelector<HTMLElement>('[data-product-modal-capacity]');
	const productModalInstall = document.querySelector<HTMLElement>('[data-product-modal-install]');
	const productModalPrice = document.querySelector<HTMLElement>('[data-product-modal-price]');
	const productModalDateStart = document.querySelector<HTMLInputElement>('[data-product-modal-date-start]');
	const productModalDateEnd = document.querySelector<HTMLInputElement>('[data-product-modal-date-end]');
	const productModalAdd = document.querySelector<HTMLButtonElement>('[data-product-modal-add]');
	const productModalQuantity = document.querySelector<HTMLElement>('[data-product-modal-quantity]');
	const productModalQuantityDecrease = document.querySelector<HTMLButtonElement>('[data-product-modal-quantity-decrease]');
	const productModalQuantityIncrease = document.querySelector<HTMLButtonElement>('[data-product-modal-quantity-increase]');
	const modalProducts: ProductModalItem[] = productModalData?.textContent ? JSON.parse(productModalData.textContent) : [];
	const modalCurrencyFormatter = new Intl.NumberFormat('lv-LV', { currency: 'EUR', style: 'currency' });
	let lastFocusedProductElement: HTMLElement | null = null;
	let activeModalProduct: ProductModalItem | null = null;
	let activeGalleryIndex = 0;
	let activeModalQuantity = 1;
	let activeProductCategoryFilter = 'all';
	let activeProductSizeFilter = 'all';
	let activeModalDateInput: HTMLInputElement | null = null;
	let viewedGalleryIndexes = new Set<number>();

	const applyProductFilters = () => {
		productCards.forEach((card) => {
			const matchesCategory = activeProductCategoryFilter === 'all' || card.dataset.productCategory === activeProductCategoryFilter;
			const matchesSize = activeProductSizeFilter === 'all' || card.dataset.productSize === activeProductSizeFilter;
			card.hidden = !matchesCategory || !matchesSize;
		});
	};

	const syncProductSizeFilters = (size: string) => {
		productSizeFilters.forEach((filter) => {
			filter.value = size;
		});
	};

	productFilterButtons.forEach((button) => {
		button.addEventListener('click', () => {
			activeProductCategoryFilter = button.dataset.productFilter ?? 'all';

			if (activeProductCategoryFilter === 'all') {
				activeProductSizeFilter = 'all';
				syncProductSizeFilters('all');
			}

			productFilterButtons.forEach((filterButton) => {
				const isActive = filterButton === button;
				filterButton.classList.toggle('is-active', isActive);
				filterButton.setAttribute('aria-pressed', String(isActive));
			});

			applyProductFilters();
		});
	});

	productSizeFilters.forEach((filter) => {
		filter.addEventListener('change', () => {
			activeProductSizeFilter = filter.value || 'all';
			syncProductSizeFilters(activeProductSizeFilter);
			applyProductFilters();
		});
	});

	const setText = (element: HTMLElement | null, text: string) => {
		if (element) {
			element.textContent = text;
		}
	};

	const formatModalCapacity = (capacity: string) => {
		const match = capacity.match(/(\d+)/);

		if (match) {
			return `${match[1]} pers.`;
		}

		return capacity.replace(/^Līdz\s+/i, '').replace(/\bpersonām\b/i, 'pers.');
	};

	const setModalQuantity = (quantity: number) => {
		activeModalQuantity = Math.min(99, Math.max(1, quantity));

		if (productModalQuantity) {
			productModalQuantity.textContent = String(activeModalQuantity);
		}

		if (productModalQuantityDecrease) {
			productModalQuantityDecrease.disabled = activeModalQuantity <= 1;
		}
	};

	const flashQuantityButton = (button: HTMLButtonElement | null) => {
		if (!button || button.disabled) return;
		button.classList.add('is-pressed');
		window.setTimeout(() => {
			button.classList.remove('is-pressed');
			button.blur();
		}, 180);
	};

	const bindDateInputToggle = (input: HTMLInputElement | null) => {
		if (!input) return;

		input.addEventListener('pointerdown', (event) => {
			if (document.activeElement === input && activeModalDateInput === input) {
				event.preventDefault();
				input.blur();
				activeModalDateInput = null;
				return;
			}

			activeModalDateInput = input;
		});

		input.addEventListener('focus', () => {
			activeModalDateInput = input;
		});

		input.addEventListener('blur', () => {
			if (activeModalDateInput === input) {
				activeModalDateInput = null;
			}
		});
	};

	const getActiveGallery = () => activeModalProduct?.galleryImages?.filter(Boolean) ?? [];

	const animateGalleryImage = () => {
		[productModalImageStage, productModalFullscreenStage].forEach((stage) => {
			if (!stage) return;
			stage.classList.remove('is-changing');
			void stage.offsetWidth;
			stage.classList.add('is-changing');
		});
	};

	const updateGalleryImage = () => {
		const gallery = getActiveGallery();
		const imageUrl = gallery[activeGalleryIndex] ?? activeModalProduct?.image ?? '';
		const hasMultipleImages = gallery.length > 1;
		viewedGalleryIndexes.add(activeGalleryIndex);

		if (productModalImage && activeModalProduct) {
			productModalImage.src = imageUrl;
			productModalImage.alt = activeModalProduct.title;
		}

		if (productModalFullscreenImage && activeModalProduct) {
			productModalFullscreenImage.src = imageUrl;
			productModalFullscreenImage.alt = activeModalProduct.title;
		}

		if (productModalImageCount) {
			productModalImageCount.textContent = gallery.length > 0 ? `${activeGalleryIndex + 1}/${gallery.length}` : '';
			productModalImageCount.hidden = !hasMultipleImages;
		}

		productModalPrev?.toggleAttribute('hidden', !hasMultipleImages);
		productModalNext?.toggleAttribute('hidden', !hasMultipleImages);
		productModalFullscreenPrev?.toggleAttribute('hidden', !hasMultipleImages);
		productModalFullscreenNext?.toggleAttribute('hidden', !hasMultipleImages);

		productModalThumbs?.querySelectorAll<HTMLButtonElement>('[data-product-modal-thumb]').forEach((button) => {
			const isActive = Number(button.dataset.productModalThumb) === activeGalleryIndex;
			button.classList.toggle('is-active', isActive);
			button.classList.toggle('is-viewed', viewedGalleryIndexes.has(Number(button.dataset.productModalThumb)));
			button.setAttribute('aria-current', String(isActive));

			if (isActive) {
				button.scrollIntoView({ behavior: 'smooth', block: 'nearest', inline: 'center' });
			}
		});

		productModalFullscreenThumbs?.querySelectorAll<HTMLButtonElement>('[data-product-modal-thumb]').forEach((button) => {
			const isActive = Number(button.dataset.productModalThumb) === activeGalleryIndex;
			button.classList.toggle('is-active', isActive);
			button.classList.toggle('is-viewed', viewedGalleryIndexes.has(Number(button.dataset.productModalThumb)));
			button.setAttribute('aria-current', String(isActive));

			if (isActive) {
				button.scrollIntoView({ behavior: 'smooth', block: 'nearest', inline: 'center' });
			}
		});

		animateGalleryImage();
	};

	const renderThumbs = (container: HTMLElement | null) => {
		const gallery = getActiveGallery();

		if (!container) {
			return;
		}

		container.replaceChildren();

		gallery.forEach((imageUrl, index) => {
			const button = document.createElement('button');
			const image = document.createElement('img');

			button.className = 'product-modal__thumb';
			button.type = 'button';
			button.dataset.productModalThumb = String(index);
			button.setAttribute('aria-label', `Atvērt attēlu ${index + 1}`);
			image.src = imageUrl;
			image.alt = activeModalProduct?.title ?? '';
			button.append(image);
			button.addEventListener('click', () => {
				activeGalleryIndex = index;
				updateGalleryImage();
				button.scrollIntoView({ behavior: 'smooth', block: 'nearest', inline: 'center' });
			});
			container.append(button);
		});
	};

	const renderGalleryThumbs = () => {
		const gallery = getActiveGallery();
		const shouldShowNav = gallery.length > 4;

		productModalThumbsPrev?.toggleAttribute('hidden', !shouldShowNav);
		productModalThumbsNext?.toggleAttribute('hidden', !shouldShowNav);
		productModalFullscreenThumbsPrev?.toggleAttribute('hidden', !shouldShowNav);
		productModalFullscreenThumbsNext?.toggleAttribute('hidden', !shouldShowNav);
		renderThumbs(productModalThumbs);
		renderThumbs(productModalFullscreenThumbs);
	};

	const moveGallery = (direction: 1 | -1) => {
		const gallery = getActiveGallery();

		if (gallery.length <= 1) {
			return;
		}

		activeGalleryIndex = (activeGalleryIndex + direction + gallery.length) % gallery.length;
		updateGalleryImage();
	};

	const setProductModalTab = (tab: string) => {
		const isExtra = tab === 'extra';

		productModalTabs.forEach((button) => {
			const isActive = button.dataset.productModalTab === tab;
			button.classList.toggle('is-active', isActive);
			button.setAttribute('aria-selected', String(isActive));
		});

		productModalBasicNodes.forEach((node) => {
			node.hidden = isExtra;
		});

		if (productModalExtraPanel) {
			productModalExtraPanel.hidden = !isExtra;
		}
	};

	const openFullscreenImage = () => {
		if (!productModalFullscreen) return;
		updateGalleryImage();
		productModalFullscreen.hidden = false;
	};

	const closeFullscreenImage = () => {
		if (!productModalFullscreen) return;
		productModalFullscreen.hidden = true;
	};

	const closeProductModal = () => {
		if (!productModal || productModal.hidden) {
			return;
		}

		closeFullscreenImage();
		productModal.classList.remove('is-open');
		document.body.classList.remove('product-modal-open');
		window.setTimeout(() => {
			productModal.hidden = true;
			lastFocusedProductElement?.focus();
			lastFocusedProductElement = null;
		}, 180);
	};

	const openProductModal = (productIndex: number, trigger: HTMLElement) => {
		const product = modalProducts[productIndex];

		if (!product || !productModal) {
			return;
		}

		activeModalProduct = product;
		activeGalleryIndex = 0;
		viewedGalleryIndexes = new Set([0]);
		setModalQuantity(1);
		lastFocusedProductElement = trigger;
		setProductModalTab('basic');
		setText(productModalCategory, product.category);
		setText(productModalTitle, product.title);
		setText(productModalDescription, product.description);
		setText(productModalAdditional, product.additionalInfo || 'Papildu informāciju precizēsim, pielāgojot piedāvājumu jūsu pasākumam.');
		setText(productModalSize, product.size);
		setText(productModalCapacity, formatModalCapacity(product.capacity));
		setText(productModalInstall, product.installTime.replace(/^.*?:\s*/, ''));
		setText(productModalPrice, modalCurrencyFormatter.format(product.priceCents / 100));
		if (productModalDateStart) productModalDateStart.value = '';
		if (productModalDateEnd) productModalDateEnd.value = '';
		renderGalleryThumbs();
		updateGalleryImage();

		productModal.hidden = false;
		document.body.classList.add('product-modal-open');
		window.requestAnimationFrame(() => {
			productModal.classList.add('is-open');
			productModalWindow?.focus();
		});
	};

	productCards.forEach((card) => {
		card.addEventListener('click', () => {
			openProductModal(Number(card.dataset.productOpen), card);
		});

		card.addEventListener('keydown', (event) => {
			if (event.key === 'Enter' || event.key === ' ') {
				event.preventDefault();
				openProductModal(Number(card.dataset.productOpen), card);
			}
		});
	});

	productModalCloseButtons.forEach((button) => {
		button.addEventListener('click', closeProductModal);
	});

	productModalTabs.forEach((button) => {
		button.addEventListener('click', () => {
			setProductModalTab(button.dataset.productModalTab ?? 'basic');
		});
	});

	productModalPrev?.addEventListener('click', () => moveGallery(-1));
	productModalNext?.addEventListener('click', () => moveGallery(1));
	productModalThumbsPrev?.addEventListener('click', () => {
		productModalThumbs?.scrollBy({ behavior: 'smooth', left: -220 });
	});
	productModalThumbsNext?.addEventListener('click', () => {
		productModalThumbs?.scrollBy({ behavior: 'smooth', left: 220 });
	});
	productModalFullscreenThumbsPrev?.addEventListener('click', () => {
		productModalFullscreenThumbs?.scrollBy({ behavior: 'smooth', left: -220 });
	});
	productModalFullscreenThumbsNext?.addEventListener('click', () => {
		productModalFullscreenThumbs?.scrollBy({ behavior: 'smooth', left: 220 });
	});
	productModalFullscreenPrev?.addEventListener('click', () => moveGallery(-1));
	productModalFullscreenNext?.addEventListener('click', () => moveGallery(1));
	productModalFullscreenOpen?.addEventListener('click', openFullscreenImage);
	productModalFullscreenCloseButtons.forEach((button) => {
		button.addEventListener('click', closeFullscreenImage);
	});

	bindDateInputToggle(productModalDateStart);
	bindDateInputToggle(productModalDateEnd);

	productModalDateStart?.addEventListener('change', () => {
		if (!productModalDateEnd || !productModalDateStart) return;
		productModalDateEnd.min = productModalDateStart.value;

		if (productModalDateEnd.value && productModalDateStart.value > productModalDateEnd.value) {
			productModalDateEnd.value = productModalDateStart.value;
		}
	});

	productModalQuantityDecrease?.addEventListener('click', () => {
		flashQuantityButton(productModalQuantityDecrease);
		setModalQuantity(activeModalQuantity - 1);
	});

	productModalQuantityIncrease?.addEventListener('click', () => {
		flashQuantityButton(productModalQuantityIncrease);
		setModalQuantity(activeModalQuantity + 1);
	});

	productModalAdd?.addEventListener('click', () => {
		if (activeModalProduct && window.LiepajasCart) {
			const startDate = productModalDateStart?.value || '';
			const endDate = productModalDateEnd?.value || '';
			const cartLineId = [activeModalProduct.id, startDate, endDate].filter(Boolean).join('::') || activeModalProduct.id;

			window.LiepajasCart.addItem(
				{
					endDate,
					id: cartLineId,
					image: activeModalProduct.image,
					priceCents: activeModalProduct.priceCents,
					productId: activeModalProduct.id,
					quantity: activeModalQuantity,
					size: activeModalProduct.size,
					startDate,
					title: activeModalProduct.title,
					variant: activeModalProduct.variant,
				},
				{ open: true },
			);
		}

		closeProductModal();
	});

	document.addEventListener('keydown', (event) => {
		if (event.key === 'Escape') {
			if (productModalFullscreen && !productModalFullscreen.hidden) {
				closeFullscreenImage();
				return;
			}

			closeProductModal();
		}
	});
</script>
