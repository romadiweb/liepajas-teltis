---
import hugeIcons from '@iconify-json/hugeicons/icons.json';
import ChevronDown from '@lucide/astro/icons/chevron-down';
import Menu from '@lucide/astro/icons/menu';
import Phone from '@lucide/astro/icons/phone';
import ShoppingBag from '@lucide/astro/icons/shopping-bag';
import X from '@lucide/astro/icons/x';

type IconifyIcon = {
	body: string;
	height?: number;
	width?: number;
};

const hugeIconSet = hugeIcons as {
	height: number;
	icons: Record<string, IconifyIcon>;
	width: number;
};

const getHugeIcon = (name: string) => {
	const icon = hugeIconSet.icons[name];

	if (!icon) {
		throw new Error(`Missing Huge Icons symbol: ${name}`);
	}

	return {
		body: icon.body,
		height: icon.height ?? hugeIconSet.height,
		width: icon.width ?? hugeIconSet.width,
	};
};

const customCategoryIcons = {
	beanBag: {
		body: `
			<g fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.45">
				<path d="M7.1 20.25h9.8c2.08 0 3.45-1.42 3.15-3.48C19.36 11.93 16.63 6.5 12 6.5s-7.36 5.43-8.05 10.27c-.3 2.06 1.07 3.48 3.15 3.48Z" />
				<path d="M8.15 18.05c1.7-.8 5.99-.8 7.7 0" />
				<path d="M9.1 8.75c1.42 1.02 4.38 1.02 5.8 0" />
				<path d="M12 6.75v11.1" />
			</g>
		`,
		height: 24,
		width: 24,
	},
	eventTent: {
		body: `
			<g fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.45">
				<path d="M2.75 10.25h18.5L17.5 5.5h-11l-3.75 4.75Z" />
				<path d="M5 10.25v9.25" />
				<path d="M9.65 10.25v9.25" />
				<path d="M14.35 10.25v9.25" />
				<path d="M19 10.25v9.25" />
				<path d="M3.75 19.5h16.5" />
				<path d="M7.8 10.25l2-4.75" />
				<path d="M12 10.25V5.5" />
				<path d="M16.2 10.25l-2-4.75" />
			</g>
		`,
		height: 24,
		width: 24,
	},
};

const currentPath = Astro.url.pathname.replace(/\/$/, '') || '/';

const isActiveNavItem = (href: string) => {
	if (!href.startsWith('/')) {
		return false;
	}

	const normalizedHref = href.replace(/\/$/, '') || '/';
	return currentPath === normalizedHref;
};

const rekvizitiItems = [
	`© ${new Date().getFullYear()} Liepājas teltis`,
	'Reģ. Nr. 00000000000',
	'PVN Nr. LV00000000000',
];

const categoryItems = [
	{ label: 'Teltis', href: '/teltis', icon: customCategoryIcons.eventTent },
	{ label: 'Grīdas segumi', href: '/gridas-segumi', icon: getHugeIcon('floor-plan') },
	{ label: 'Galdi un krēsli', href: '/galdi-un-kresli', icon: getHugeIcon('dining-table') },
	{ label: 'Āra sildītāji', href: '/ara-silditaji', icon: getHugeIcon('heater') },
	{ label: 'Pufi', href: '/pufi', icon: customCategoryIcons.beanBag },
	{ label: 'Pasākumu aksesuāri', href: '#kontakti', icon: getHugeIcon('balloons') },
];

const navItems = [
	{ label: 'Noma', href: '/#kategorijas', hasDropdown: true },
	{ label: 'Piegāde', href: '/#piegade' },
	{ label: 'Par mums', href: '/par-mums' },
	{ label: 'Kontakti', href: '/kontakti' },
];

const showCategoryStrip = false;

const isRentalCategoryActive = categoryItems.some((item) => isActiveNavItem(item.href));
---

<header class="site-header">
	<div class="site-header__shell">
		<div class="site-header__bar">
			<a class="site-header__logo" href="/" aria-label="Liepājas teltis sākums">
				<slot name="logo">
					<span class="site-header__logo-placeholder">Logo</span>
				</slot>
			</a>

			<nav class="site-header__nav" aria-label="Galvenā navigācija">
				{
					navItems.map((item) =>
						item.hasDropdown ? (
							<div class="site-header__nav-dropdown">
								<a
									class:list={{ 'is-active': isRentalCategoryActive }}
									href={item.href}
									aria-current={isRentalCategoryActive ? 'page' : undefined}
								>
									<span>{item.label}</span>
									<ChevronDown class="site-header__dropdown-indicator" aria-hidden="true" />
								</a>
								<div class="site-header__dropdown-panel" aria-label="Nomas kategorijas">
									{categoryItems.map((category) => (
										<a class:list={{ 'is-active': isActiveNavItem(category.href) }} href={category.href}>
											<svg
												aria-hidden="true"
												viewBox={`0 0 ${category.icon.width} ${category.icon.height}`}
												set:html={category.icon.body}
											/>
											<span>{category.label}</span>
										</a>
									))}
								</div>
							</div>
						) : (
							<a class:list={{ 'is-active': isActiveNavItem(item.href) }} href={item.href} aria-current={isActiveNavItem(item.href) ? 'page' : undefined}>
								{item.label}
							</a>
						),
					)
				}
			</nav>

			<div class="site-header__actions">
				<button class="site-header__cart" data-cart-open type="button" aria-label="Atvērt nomas sarakstu">
					<ShoppingBag aria-hidden="true" />
					<span data-cart-count hidden>0</span>
				</button>
				<a class="site-header__contact" href="tel:+37129373231">
				<Phone aria-hidden="true" />
				<span>
					<small>Sazināties</small>
					<strong>+371 29 373 231</strong>
				</span>
				</a>
			</div>
			<button class="site-header__mobile-cart" data-cart-open type="button" aria-label="Atvērt nomas sarakstu">
				<ShoppingBag aria-hidden="true" />
				<span data-cart-count hidden>0</span>
			</button>
			<div class="site-header__mobile-menu">
				<input id="site-header-mobile-menu" class="site-header__menu-toggle" type="checkbox" aria-hidden="true" tabindex="-1" />
				<label class="site-header__menu-button" for="site-header-mobile-menu" aria-label="Toggle navigation" title="Menu">
					<span class="site-header__menu-icon site-header__menu-icon--open">
						<Menu aria-hidden="true" />
					</span>
					<span class="site-header__menu-icon site-header__menu-icon--close">
						<X aria-hidden="true" />
					</span>
				</label>
				<label class="site-header__mobile-backdrop" for="site-header-mobile-menu" aria-label="Close navigation"></label>
				<nav class="site-header__mobile-panel" aria-label="Mobile navigation">
					<ul class="site-header__mobile-list menu menu-vertical">
						{
							navItems.map((item) => (
								item.hasDropdown ? (
									<li class:list={['site-header__mobile-item--dropdown', { 'is-open': isRentalCategoryActive }]}>
										<button
											class:list={['site-header__mobile-dropdown-toggle', { 'is-active': isRentalCategoryActive }]}
											data-mobile-rental-toggle
											type="button"
											aria-expanded={isRentalCategoryActive ? 'true' : 'false'}
										>
											<span>{item.label}</span>
											<ChevronDown aria-hidden="true" />
										</button>
										<ul class="site-header__mobile-sublist" aria-label="Nomas kategorijas" aria-hidden={isRentalCategoryActive ? 'false' : 'true'}>
											{categoryItems.map((category) => (
												<li>
													<a class:list={{ 'is-active': isActiveNavItem(category.href) }} href={category.href}>{category.label}</a>
												</li>
											))}
										</ul>
									</li>
								) : (
									<li>
										<a class:list={{ 'is-active': isActiveNavItem(item.href) }} href={item.href} aria-current={isActiveNavItem(item.href) ? 'page' : undefined}>{item.label}</a>
									</li>
								)
							))
						}
						<li class="site-header__mobile-contact">
							<button data-cart-open type="button">
								<ShoppingBag aria-hidden="true" />
								<span>Nomas saraksts</span>
								<span class="site-header__mobile-cart-count" data-cart-count hidden>0</span>
							</button>
							<a href="tel:+37129373231">
								<Phone aria-hidden="true" />
								<span>+371 29 373 231</span>
							</a>
						</li>
					</ul>
					<div class="site-header__mobile-rekviziti" aria-label="Rekviziti">
						<strong>Rekvizīti</strong>
						{
							rekvizitiItems.map((item) => (
								<span>{item}</span>
							))
						}
					</div>
				</nav>
			</div>
		</div>

		{/* Category strip paused for now. Set showCategoryStrip to true to restore it. */}
		{
			showCategoryStrip && (
				<nav class="site-header__categories" aria-label="Nomas kategorijas">
					{categoryItems.map((item) => {
						return (
							<a class={isActiveNavItem(item.href) ? 'is-active' : undefined} href={item.href}>
								<svg
									aria-hidden="true"
									class="site-header__category-icon"
									viewBox={`0 0 ${item.icon.width} ${item.icon.height}`}
									set:html={item.icon.body}
								/>
								<span>{item.label}</span>
							</a>
						);
					})}
				</nav>
			)
		}
	</div>
</header>

<script>
	const mobileMenuToggle = document.querySelector<HTMLInputElement>('#site-header-mobile-menu');
	const mobileMenuLinks = document.querySelectorAll<HTMLAnchorElement>('.site-header__mobile-panel a');
	const mobileMenuButtons = document.querySelectorAll<HTMLButtonElement>('.site-header__mobile-panel button');
	const mobileRentalToggles = document.querySelectorAll<HTMLButtonElement>('[data-mobile-rental-toggle]');
	let mobileMenuScrollY = 0;
	const shouldOpenMobileRentalByDefault = document.querySelector('.site-header__mobile-dropdown-toggle.is-active') !== null;

	const closeMobileRentalDropdowns = () => {
		mobileRentalToggles.forEach((button) => {
			const item = button.closest('.site-header__mobile-item--dropdown');
			const sublist = item?.querySelector<HTMLElement>('.site-header__mobile-sublist');

			item?.classList.remove('is-open');
			button.setAttribute('aria-expanded', 'false');
			sublist?.setAttribute('aria-hidden', 'true');
		});
	};

	const setMobileMenuOpen = (isOpen: boolean) => {
		if (isOpen) {
			if (!shouldOpenMobileRentalByDefault) {
				closeMobileRentalDropdowns();
			}
			mobileMenuScrollY = window.scrollY;
			document.body.classList.add('site-header-menu-open');
			document.body.style.top = `-${mobileMenuScrollY}px`;
			return;
		}

		document.body.classList.remove('site-header-menu-open');
		document.body.style.top = '';
		window.scrollTo(0, mobileMenuScrollY);
		closeMobileRentalDropdowns();
	};

	mobileMenuToggle?.addEventListener('change', () => {
		setMobileMenuOpen(mobileMenuToggle.checked);
	});

	mobileMenuLinks.forEach((link) => {
		link.addEventListener('click', () => {
			if (mobileMenuToggle) {
				mobileMenuToggle.checked = false;
				setMobileMenuOpen(false);
			}
		});
	});

	mobileMenuButtons.forEach((button) => {
		button.addEventListener('click', () => {
			if (button.matches('[data-mobile-rental-toggle]')) {
				return;
			}

			if (mobileMenuToggle) {
				mobileMenuToggle.checked = false;
				setMobileMenuOpen(false);
			}
		});
	});

	mobileRentalToggles.forEach((button) => {
		button.addEventListener('click', () => {
			const item = button.closest('.site-header__mobile-item--dropdown');
			const sublist = item?.querySelector<HTMLElement>('.site-header__mobile-sublist');
			const isOpen = !item?.classList.contains('is-open');

			item?.classList.toggle('is-open', isOpen);
			button.setAttribute('aria-expanded', String(isOpen));
			sublist?.setAttribute('aria-hidden', String(!isOpen));
		});
	});
</script>

<style>
	.site-header {
		position: sticky;
		top: 0;
		z-index: 80;
		padding: 0 clamp(1rem, 3vw, 1.5rem) 0.65rem;
		background: linear-gradient(180deg, var(--color-background) 0%, rgba(246, 241, 231, 0) 100%);
	}

	.site-header:has(.site-header__menu-toggle:checked) {
		z-index: 90;
	}

	:global(body.site-header-menu-open) {
		position: fixed;
		right: 0;
		left: 0;
		width: 100%;
		overflow: hidden;
	}

	.site-header__shell {
		max-width: 1200px;
		margin: 0 auto;
		overflow: visible;
		display: grid;
		gap: 0;
		background: #6B7A4A;
		border: 1px solid rgba(255, 255, 255, 0.16);
		border-top: 0;
		border-radius: 0 0 1.65rem 1.65rem;
		box-shadow: var(--shadow-strong);
	}

	.site-header__bar {
		position: relative;
		width: 100%;
		min-height: 4.35rem;
		margin: 0;
		padding: 0.72rem clamp(1rem, 3vw, 1.7rem);
		display: grid;
		grid-template-columns: minmax(10rem, 1fr) auto minmax(10rem, 1fr);
		align-items: center;
		gap: 1rem;
		color: var(--color-surface);
		background:
			radial-gradient(
				95% 85% at 50% 100%,
				rgba(203, 183, 154, 0.3) 0%,
				rgba(203, 183, 154, 0.14) 34%,
				transparent 68%
			),
			#6B7A4A;
		border-radius: 0 0 1.65rem 1.65rem;
	}

	.site-header__logo,
	.site-header__contact,
	.site-header__cart,
	.site-header__mobile-cart,
	.site-header__menu-button,
	.site-header__mobile-list button,
	.site-header__mobile-list a,
	.site-header__nav > a,
	.site-header__nav-dropdown > a,
	.site-header__dropdown-panel a,
	.site-header__categories a {
		text-decoration: none;
		transition:
			color 0.2s ease,
			background-color 0.2s ease,
			border-color 0.2s ease,
			opacity 0.22s ease,
			transform 0.2s ease;
	}

	.site-header__logo {
		justify-self: start;
		min-width: 8rem;
		color: var(--color-surface);
	}

	.site-header__logo-placeholder {
		display: inline-flex;
		min-height: 2.35rem;
		align-items: center;
		padding: 0.36rem 0.78rem;
		color: rgba(255, 255, 255, 0.86);
		border: 1px dashed rgba(203, 183, 154, 0.56);
		border-radius: 999px;
		font-size: 0.78rem;
		font-weight: 750;
		letter-spacing: 0.08em;
		text-transform: uppercase;
	}

	.site-header__nav {
		justify-self: center;
		align-self: stretch;
		display: flex;
		align-items: center;
		justify-content: center;
		gap: clamp(0.45rem, 1.5vw, 0.95rem);
	}

	.site-header__nav > a,
	.site-header__nav-dropdown > a {
		position: relative;
		display: inline-flex;
		min-height: 2.15rem;
		align-items: center;
		padding: 0.42rem 0.78rem;
		color: rgba(255, 255, 255, 0.9);
		border-radius: 999px;
		font-size: 0.94rem;
		font-weight: 600;
		opacity: 0.95;
	}

	.site-header__nav > a::after,
	.site-header__nav-dropdown > a::after {
		position: absolute;
		right: 0.72rem;
		bottom: 0.18rem;
		left: 0.72rem;
		height: 2px;
		background: currentColor;
		border-radius: 999px;
		content: "";
		opacity: 0;
		transform: scaleX(0.42);
		transition:
			opacity 180ms ease,
			transform 180ms ease;
	}

	.site-header__nav > a.is-active,
	.site-header__nav-dropdown > a.is-active {
		color: rgba(255, 255, 255, 0.9);
		background: transparent;
		opacity: 1;
	}

	.site-header__nav > a.is-active::after,
	.site-header__nav > a:hover::after,
	.site-header__nav-dropdown > a.is-active::after,
	.site-header__nav-dropdown > a:hover::after {
		opacity: 0.86;
		transform: scaleX(1);
	}

	.site-header__nav-dropdown {
		position: relative;
		align-self: stretch;
		display: inline-flex;
		align-items: center;
	}

	.site-header__nav-dropdown::before {
		position: absolute;
		top: 100%;
		right: -9rem;
		left: -9rem;
		height: 1.7rem;
		content: "";
	}

	.site-header__dropdown-indicator {
		width: 0.9rem;
		height: 0.9rem;
		margin-left: 0.18rem;
		flex: 0 0 auto;
		stroke-width: 2.2;
		transition: transform 180ms ease;
	}

	.site-header__nav-dropdown:hover .site-header__dropdown-indicator,
	.site-header__nav-dropdown:focus-within .site-header__dropdown-indicator {
		transform: rotate(180deg);
	}

	.site-header__dropdown-panel {
		position: absolute;
		top: calc(100% + 0.72rem - 1px);
		left: 50%;
		z-index: 100;
		width: max-content;
		min-width: 17.5rem;
		padding: 0.62rem;
		display: grid;
		gap: 0.18rem;
		background: rgba(255, 255, 255, 0.96);
		border: 1px solid rgba(222, 212, 198, 0.88);
		border-top: 0;
		border-radius: 0 0 1rem 1rem;
		box-shadow: 0 18px 40px rgba(75, 64, 56, 0.16);
		opacity: 0;
		pointer-events: none;
		transform: translate(-50%, -0.25rem);
		transition:
			opacity 180ms ease,
			transform 180ms ease,
			visibility 0s linear 180ms;
		visibility: hidden;
	}

	.site-header__nav-dropdown:hover .site-header__dropdown-panel,
	.site-header__nav-dropdown:focus-within .site-header__dropdown-panel {
		opacity: 1;
		pointer-events: auto;
		transform: translate(-50%, 0);
		transition:
			opacity 180ms ease,
			transform 180ms ease;
		visibility: visible;
	}

	.site-header__dropdown-panel a {
		min-height: 2.65rem;
		padding: 0.48rem 0.62rem;
		display: grid;
		grid-template-columns: 1.75rem minmax(0, 1fr);
		align-items: center;
		gap: 0.58rem;
		color: var(--color-bark);
		border-radius: 0.72rem;
		font-size: 0.88rem;
		font-weight: 680;
		line-height: 1.2;
		opacity: 1;
	}

	.site-header__dropdown-panel a::after {
		display: none;
	}

	.site-header__dropdown-panel a:hover,
	.site-header__dropdown-panel a.is-active {
		color: var(--color-bark);
		background: var(--color-background-soft);
		transform: none;
	}

	.site-header__dropdown-panel svg {
		width: 1.16rem;
		height: 1.16rem;
		color: #6B7A4A;
		stroke-width: 1.85;
	}

	.site-header__contact {
		display: inline-flex;
		min-height: 2.15rem;
		align-items: center;
		gap: 0.55rem;
		padding: 0.34rem 0;
		color: var(--color-surface);
		opacity: 0.95;
	}

	.site-header__actions {
		justify-self: end;
		display: inline-flex;
		align-items: center;
		gap: 0.8rem;
	}

	.site-header__cart {
		position: relative;
		width: 2.45rem;
		height: 2.45rem;
		display: grid;
		place-items: center;
		color: var(--color-surface);
		background: transparent;
		cursor: pointer;
	}

	.site-header__cart:hover {
		color: var(--color-background);
		border-color: rgba(255, 255, 255, 0.34);
		transform: translateY(-2px);
	}

	.site-header__cart svg {
		width: 1.05rem;
		height: 1.05rem;
		stroke-width: 2.25;
	}

	.site-header__cart span {
		position: absolute;
		top: -0.36rem;
		right: -0.3rem;
		min-width: 1.08rem;
		height: 1.08rem;
		padding: 0 0.22rem;
		display: inline-grid;
		place-items: center;
		color: var(--color-surface);
		background: #86c425;
		border: 1px solid rgba(255, 255, 255, 0.78);
		border-radius: 999px;
		font-size: 0.64rem;
		font-weight: 820;
		line-height: 1;
	}

	.site-header__mobile-cart {
		position: relative;
		width: 2.65rem;
		height: 2.65rem;
		display: none;
		place-items: center;
		color: var(--color-surface);
		background: transparent;
		border: 0;
		border-radius: 999px;
		cursor: pointer;
	}

	.site-header__mobile-cart:hover {
		color: var(--color-background);
		transform: translateY(-2px);
	}

	.site-header__mobile-cart svg {
		width: 1.22rem;
		height: 1.22rem;
		stroke-width: 2.25;
	}

	.site-header__mobile-cart > span {
		position: absolute;
		top: 0.3rem;
		right: 0.26rem;
		min-width: 1.08rem;
		height: 1.08rem;
		padding: 0 0.22rem;
		display: inline-grid;
		place-items: center;
		color: var(--color-surface);
		background: #86c425;
		border: 1px solid rgba(255, 255, 255, 0.78);
		border-radius: 999px;
		font-size: 0.64rem;
		font-weight: 820;
		line-height: 1;
	}

	.site-header__contact svg {
		width: 1rem;
		height: 1rem;
		flex: 0 0 auto;
		stroke-width: 2.3;
	}

	.site-header__contact span {
		display: grid;
		gap: 0.03rem;
		line-height: 1.05;
	}

	.site-header__contact small {
		color: rgba(255, 255, 255, 0.64);
		font-size: 0.64rem;
		font-weight: 650;
		letter-spacing: 0.05em;
		text-transform: uppercase;
	}

	.site-header__contact strong {
		position: relative;
		display: inline-flex;
		color: var(--color-surface);
		font-size: 0.86rem;
		font-weight: 650;
		white-space: nowrap;
	}

	.site-header__contact strong::after {
		position: absolute;
		right: 0;
		bottom: -0.18rem;
		left: 0;
