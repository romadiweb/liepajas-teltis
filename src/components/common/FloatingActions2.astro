---
const actions = [
	{
		label: 'WhatsApp',
		href: '#',
		icon: 'whatsapp',
	},
	{
		label: 'Zvanīt',
		href: '#',
		icon: 'phone',
	},
];
---

<nav class="floating-actions" aria-label="Ātrie kontakti">
	{
		actions.map((action) => (
			<a class="floating-actions__button" href={action.href} aria-label={action.label} title={action.label}>
				{
					action.icon === 'whatsapp' ? (
						<img src="/icons/whatsapp.svg" alt="" loading="eager" decoding="async" />
					) : (
						<svg aria-hidden="true" viewBox="0 0 24 24" focusable="false">
							<path d="M20.6 16.8v2.9a1.9 1.9 0 0 1-2.1 1.9 18.8 18.8 0 0 1-8.2-2.9A18.5 18.5 0 0 1 4.6 13 18.8 18.8 0 0 1 1.7 4.8 1.9 1.9 0 0 1 3.6 2.7h2.9a1.9 1.9 0 0 1 1.9 1.6c.1 1 .4 2 .7 2.9a1.9 1.9 0 0 1-.4 2l-1.2 1.2a15.1 15.1 0 0 0 5.7 5.7l1.2-1.2a1.9 1.9 0 0 1 2-.4c.9.3 1.9.6 2.9.7a1.9 1.9 0 0 1 1.3 1.6Z" />
						</svg>
					)
				}
			</a>
		))
	}
</nav>
