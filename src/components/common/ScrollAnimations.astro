<script>
	import { animate, inView } from 'motion';

	function initialiseAnimations() {
		const reduceMotion = window.matchMedia(
			'(prefers-reduced-motion: reduce)'
		).matches;

		if (reduceMotion) {
			document.documentElement.classList.remove('motion-preload');
		}

		const elements =
			document.querySelectorAll<HTMLElement>('[data-reveal]');

		elements.forEach((element) => {
			if (element.dataset.revealInitialised === 'true') {
				return;
			}

			element.dataset.revealInitialised = 'true';

			if (reduceMotion) {
				return;
			}

			const direction = element.dataset.reveal ?? 'up';

			const initialX =
				direction === 'left'
					? -32
					: direction === 'right'
						? 32
						: 0;

			const initialY = direction === 'up' ? 24 : 0;

			element.style.opacity = '0';
			element.style.transform = `translate3d(${initialX}px, ${initialY}px, 0)`;

			inView(
				element,
				() => {
					animate(
						element,
						{
							opacity: 1,
							x: 0,
							y: 0,
						},
						{
							duration: 2.0,
							ease: [0.22, 1, 0.36, 1],
						}
					);
				},
				{
					amount: 0.15,
					margin: '0px 0px -8% 0px',
				}
			);
		});

		requestAnimationFrame(() => {
			document.documentElement.classList.remove('motion-preload');
		});
	}

	initialiseAnimations();

	document.addEventListener('astro:page-load', initialiseAnimations);
</script>

<style is:global>
	[data-reveal] {
		will-change: opacity, transform;
	}

	html.motion-preload [data-reveal] {
		opacity: 0;
		transform: translate3d(0, 24px, 0);
	}

	html.motion-preload [data-reveal="left"] {
		transform: translate3d(-32px, 0, 0);
	}

	html.motion-preload [data-reveal="right"] {
		transform: translate3d(32px, 0, 0);
	}

	@media (prefers-reduced-motion: reduce) {
		html.motion-preload [data-reveal] {
			opacity: 1;
			transform: none;
		}
	}
</style>
