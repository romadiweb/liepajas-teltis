<script>
	import { animate, inView, scroll, stagger } from 'motion';

	function initialiseLandingAnimations() {
		const page =
			document.querySelector<HTMLElement>('[data-landing-page]');

		if (!page || page.dataset.motionReady === 'true') {
			return;
		}

		page.dataset.motionReady = 'true';

		const reduceMotion = window.matchMedia(
			'(prefers-reduced-motion: reduce)'
		).matches;

		if (reduceMotion) {
			page.removeAttribute('data-landing-preview');
			return;
		}

		const mobile = window.matchMedia('(max-width: 700px)').matches;
		const distance = mobile ? 34 : 72;
		const firstViewportHeight = window.innerHeight || document.documentElement.clientHeight;
		const setPreviewState = (
			elements: HTMLElement | HTMLElement[] | NodeListOf<HTMLElement>,
			opacity: number,
			transform: string
		) => {
			const targets =
				elements instanceof HTMLElement
					? [elements]
					: Array.from(elements);

			targets.forEach((element) => {
				element.style.opacity = String(opacity);
				element.style.transform = transform;
			});
		};

		/*
		 * Hero entrance
		 */
		const hero =
			page.querySelector<HTMLElement>('[data-landing-hero]');

		if (hero) {
			const media =
				hero.querySelector<HTMLElement>('[data-hero-media]');

			const eyebrow =
				hero.querySelector<HTMLElement>('[data-hero-eyebrow]');

			const titleLines =
				hero.querySelectorAll<HTMLElement>('[data-hero-line]');

			const copy =
				hero.querySelectorAll<HTMLElement>('[data-hero-copy]');

			const actions =
				hero.querySelector<HTMLElement>('[data-hero-actions]');

			if (media) {
				const mediaRadius = getComputedStyle(media).getPropertyValue('--landing-hero-media-radius').trim() || '0px';

				animate(
					media,
					{
						opacity: [0, 1],
						scale: [1.1, 1],
						clipPath: [
							`inset(0 100% 0 0 round ${mediaRadius})`,
							`inset(0 0% 0 0 round ${mediaRadius})`,
						],
					},
					{
						duration: 1.25,
						ease: [0.22, 1, 0.36, 1],
					}
				);
			}

			if (eyebrow) {
				animate(
					eyebrow,
					{
						opacity: [0, 1],
						y: [24, 0],
					},
					{
						duration: 0.65,
						delay: 0.15,
						ease: [0.22, 1, 0.36, 1],
					}
				);
			}

			if (titleLines.length) {
				animate(
					titleLines,
					{
						y: ['115%', '0%'],
						rotate: [2, 0],
					},
					{
						duration: 0.9,
						delay: stagger(0.11, {
							startDelay: 0.22,
						}),
						ease: [0.22, 1, 0.36, 1],
					}
				);
			}

			if (copy.length) {
				animate(
					copy,
					{
						opacity: [0, 1],
						y: [36, 0],
					},
					{
						duration: 0.8,
						delay: stagger(0.1, {
							startDelay: 0.55,
						}),
						ease: [0.22, 1, 0.36, 1],
					}
				);
			}

			if (actions) {
				animate(
					actions,
					{
						opacity: [0, 1],
						y: [28, 0],
						scale: [0.94, 1],
					},
					{
						duration: 0.75,
						delay: 0.78,
						ease: [0.22, 1, 0.36, 1],
					}
				);
			}
		}

		/*
		 * Alternating large section reveals
		 */
		const sections =
			page.querySelectorAll<HTMLElement>('[data-landing-section]');

		sections.forEach((section, index) => {
			const media =
				section.querySelector<HTMLElement>('[data-section-media]');

			const items =
				section.querySelectorAll<HTMLElement>('[data-section-item]');

			const specifiedDirection = section.dataset.enter;

			const direction =
				specifiedDirection === 'right'
					? 1
					: specifiedDirection === 'left'
						? -1
						: index % 2 === 0
							? -1
							: 1;

			if (media) {
				setPreviewState(
					media,
					0.36,
					`translateX(${direction * distance}px) scale(0.94)`
				);
			}

			if (items.length) {
				setPreviewState(
					items,
					0.5,
					`translateY(${mobile ? 28 : 48}px)`
				);
			}

			inView(
				section,
				() => {
					if (media) {
						animate(
							media,
							{
								opacity: 1,
								x: 0,
								scale: 1,
							},
							{
								duration: 1,
								ease: [0.22, 1, 0.36, 1],
							}
						);
					}

					if (items.length) {
						animate(
							items,
							{
								opacity: 1,
								y: 0,
							},
							{
								duration: 0.8,
								delay: stagger(0.1, {
									startDelay: 0.12,
								}),
								ease: [0.22, 1, 0.36, 1],
							}
						);
					}
				},
				{
					amount: mobile ? 0.32 : 0.3,
					margin: '0px 0px -18% 0px',
				}
			);
		});

		/*
		 * Product/service card wave
		 */
		const grids =
			page.querySelectorAll<HTMLElement>('[data-landing-grid]');

		grids.forEach((grid) => {
			const cards =
				Array.from(grid.querySelectorAll<HTMLElement>('[data-grid-item]'));

			if (!cards.length) {
				return;
			}

			grid.classList.add('is-previewing');

			const getGridColumnCount = () => {
				const columns = getComputedStyle(grid)
					.gridTemplateColumns
					.split(' ')
					.filter(Boolean).length;

				return Math.max(1, columns || (mobile ? 2 : 3));
			};

			let cardsPlayed = false;

			const playCardsInRows = () => {
				if (cardsPlayed) {
					return;
				}

				cardsPlayed = true;
				grid.classList.remove('is-previewing');
				grid.classList.add('is-revealed');
				const columns = getGridColumnCount();
				const rows = cards.reduce<HTMLElement[][]>((groups, card, index) => {
					const rowIndex = Math.floor(index / columns);
					groups[rowIndex] ??= [];
					groups[rowIndex].push(card);
					return groups;
				}, []);

				rows.forEach((row, rowIndex) => {
					animate(
						row,
						{
							opacity: 1,
							y: 0,
							scale: 1,
						},
						{
							duration: 0.72,
							delay: stagger(mobile ? 0.05 : 0.07, {
								startDelay: rowIndex * (mobile ? 0.16 : 0.14),
							}),
							ease: [0.22, 1, 0.36, 1],
						}
					);
				});
			};

			setPreviewState(
				cards,
				0.34,
				`translateY(${mobile ? 32 : 58}px) scale(0.92)`
			);

			if (mobile && grid.getBoundingClientRect().top < firstViewportHeight) {
				const triggerVisibleGrid = () => {
					if (cardsPlayed) {
						return;
					}

					const triggerPoint = firstViewportHeight * 0.7;

					if (grid.getBoundingClientRect().top > triggerPoint) {
						return;
					}

					window.removeEventListener('scroll', triggerVisibleGrid);
					window.removeEventListener('resize', triggerVisibleGrid);
					playCardsInRows();
				};

				window.addEventListener('scroll', triggerVisibleGrid, { passive: true });
				window.addEventListener('resize', triggerVisibleGrid);
				triggerVisibleGrid();
				return;
			}

			inView(
				grid,
				playCardsInRows,
				{
					amount: mobile ? 0.22 : 0.28,
					margin: '0px 0px -18% 0px',
				}
			);
		});

		/*
		 * Subtle image parallax on desktop only
		 */
		if (!mobile) {
			const parallaxElements =
				page.querySelectorAll<HTMLElement>('[data-parallax]');

			parallaxElements.forEach((element) => {
				const target =
					element.closest<HTMLElement>('[data-parallax-section]') ??
					element;

				const animation = animate(
					element,
					{
						y: ['-4%', '4%'],
						scale: [1.04, 1.09],
					},
					{
						ease: 'linear',
					}
				);

				scroll(animation, {
					target,
					offset: ['start end', 'end start'],
				});
			});
		}

		requestAnimationFrame(() => {
			page.removeAttribute('data-landing-preview');
		});
	}

	initialiseLandingAnimations();

	document.addEventListener(
		'astro:page-load',
		initialiseLandingAnimations
	);
</script>

<style is:global>
	.landing-title-line {
		display: block;
		overflow: hidden;
		padding-bottom: 0.08em;
		margin-bottom: -0.08em;
	}

	[data-hero-line] {
		display: block;
		transform-origin: left bottom;
	}

	[data-hero-media],
	[data-section-media],
	[data-grid-item] {
		will-change: opacity, transform;
	}

	[data-landing-grid] {
		position: relative;
	}

	[data-landing-page][data-landing-preview] [data-section-media] {
		opacity: 0.36;
		transform: translateX(34px) scale(0.94);
	}

	[data-landing-page][data-landing-preview] [data-section-item] {
		opacity: 0.5;
		transform: translateY(48px);
	}

	[data-landing-page][data-landing-preview] [data-grid-item] {
		opacity: 0.34;
		transform: translateY(58px) scale(0.92);
	}

	[data-landing-grid]::before {
		position: absolute;
		inset: 1.15rem -0.75rem auto;
		z-index: 2;
		height: min(5.5rem, 20%);
		background: linear-gradient(180deg, var(--color-background, #f6f1e7) 0%, rgba(246, 241, 231, 0.56) 48%, rgba(246, 241, 231, 0) 100%);
		content: "";
		opacity: 0;
		pointer-events: none;
		transition: opacity 420ms ease;
	}

	[data-landing-grid].is-previewing::before {
		opacity: 1;
	}

	[data-landing-page][data-landing-preview] [data-landing-grid]::before {
		opacity: 1;
	}

	[data-landing-grid].is-revealed::before {
		opacity: 0;
	}

	@media (max-width: 700px) {
		[data-landing-page][data-landing-preview] [data-section-item] {
			transform: translateY(28px);
		}

		[data-landing-page][data-landing-preview] [data-grid-item] {
			transform: translateY(32px) scale(0.92);
		}
	}

	[data-hero-media],
	[data-section-media] {
		overflow: hidden;
	}

	[data-parallax] {
		will-change: transform;
	}

	@media (prefers-reduced-motion: reduce) {
		[data-hero-line],
		[data-hero-media],
		[data-section-media],
		[data-section-item],
		[data-grid-item],
		[data-parallax] {
			opacity: 1 !important;
			transform: none !important;
			clip-path: none !important;
		}
	}
</style>
